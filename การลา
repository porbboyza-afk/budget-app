                                        </table>
                                    </div>
                                </div>
                            </div>
                        )}

                    </main>
                </div>
            );
        };

        // Utility: Convert standard date object to BE YYYY-MM-DD string
        const toBEYearString = (dateObj) => {
            const y = dateObj.getFullYear() + 543;
            const m = String(dateObj.getMonth() + 1).padStart(2, '0');
            const d = String(dateObj.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        };

        // Check if date checkStr lies between startStr and endStr inclusive (all in BE format)
        const isDateInRange = (checkStr, startStr, endStr) => {
            if (!checkStr || !startStr || !endStr) return false;
            try {
                const check = parseInt(checkStr.replace(/-/g, ''));
                const start = parseInt(startStr.replace(/-/g, ''));
                const end = parseInt(endStr.replace(/-/g, ''));
                return check >= start && check <= end;
            } catch (e) {
                return false;
            }
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
