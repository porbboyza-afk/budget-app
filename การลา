        ];

        // Helper component for Lucide Icons
        const Icon = ({ name, size = 20, className = "" }) => {
            const [ready, setReady] = useState(!!window.lucide);

            useEffect(() => {
                if (window.lucide) {
                    setReady(true);
                    return;
                }
                const interval = setInterval(() => {
                    if (window.lucide) {
                        setReady(true);
                        clearInterval(interval);
                    }
                }, 100);
                return () => clearInterval(interval);
            }, []);

            if (!ready || !window.lucide || !window.lucide.icons) {
                return <span className={`inline-block ${className}`} style={{ width: size, height: size, minWidth: size, minHeight: size }}></span>;
            }

            const getIconNode = (rawName) => {
                if (window.lucide.icons[rawName]) return window.lucide.icons[rawName];
                const pascalName = rawName.split('-').map(part => part.charAt(0).toUpperCase() + part.slice(1)).join('');
                if (window.lucide.icons[pascalName]) return window.lucide.icons[pascalName];
                const lowerName = rawName.replace(/-/g, '').toLowerCase();
                const foundKey = Object.keys(window.lucide.icons).find(k => k.toLowerCase() === lowerName);
                if (foundKey) return window.lucide.icons[foundKey];
                return null;
            };

            const node = getIconNode(name);
            if (!node) {
                return <span className={`inline-block ${className}`} style={{ width: size, height: size, minWidth: size, minHeight: size }}></span>;
            }

            return (
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width={size}
                    height={size}
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    strokeWidth="2"
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    className={`inline-block ${className}`}
                    style={{ minWidth: size, minHeight: size }}
                >
                    {node.map(([tag, attrs], idx) => {
                        const Tag = tag;
                        return <Tag key={idx} {...attrs} />;
                    })}
                </svg>
            );
        };

        const App = () => {
            const [isOnline, setIsOnline] = useState(navigator.onLine);
            const [activeTab, setActiveTab] = useState('dashboard');
            const [teachers, setTeachers] = useState([]);
            const [records, setRecords] = useState([]);
            const [isSubmitting, setIsSubmitting] = useState(false);
            
            // Search and Filters
            const [filterTeacher, setFilterTeacher] = useState('');
            const [filterType, setFilterType] = useState('all');
            const [filterYear, setFilterYear] = useState('2569');

            // Form States
            const [formData, setFormData] = useState({
                id: '',
                userId: '',
                type: 'ลากิจ',
                startDate: '',
                endDate: '',
                reason: '',
                substitute: '',
                status: 'approved'
            });

            // Teacher Form States
            const [showTeacherModal, setShowTeacherModal] = useState(false);
            const [teacherForm, setTeacherForm] = useState({ id: '', name: '', pos: '' });

            // Confirm Delete Modal States
            const [deleteTarget, setDeleteTarget] = useState(null); // { type: 'record'|'teacher', id: '' }
            const [editMode, setEditMode] = useState(false);

            // Notification / Alert state
            const [alertMsg, setAlertMsg] = useState({ text: '', type: '' });

            // Keep reference to latest states to prevent useEffect dependency leaks
            const recordsRef = useRef(records);
            const teachersRef = useRef(teachers);

            useEffect(() => {
                recordsRef.current = records;
            }, [records]);

            useEffect(() => {
                teachersRef.current = teachers;
            }, [teachers]);

            // Check connection status
            useEffect(() => {
                const handleOnline = () => setIsOnline(true);
                const handleOffline = () => setIsOnline(false);
                window.addEventListener('online', handleOnline);
                window.addEventListener('offline', handleOffline);
                return () => {
                    window.removeEventListener('online', handleOnline);
                    window.removeEventListener('offline', handleOffline);
                };
            }, []);

            // 1. Initial Load from LocalStorage
            useEffect(() => {
                const localT = localStorage.getItem('school_leave_teachers');
                const localR = localStorage.getItem('school_leave_records');

                if (localT) {
                    setTeachers(JSON.parse(localT));
                } else {
                    localStorage.setItem('school_leave_teachers', JSON.stringify(defaultTeachers));
                    setTeachers(defaultTeachers);
                }

                if (localR) {
                    setRecords(JSON.parse(localR));
                }
            }, []);

            // Apps Script Helper for POST API requests
            const callAppsScript = async (action, sheet, dataOrId) => {
                if (!APPS_SCRIPT_URL) return { error: "APPS_SCRIPT_URL is not set" };
                try {
                    const payload = { action, sheet };
                    if (action === 'save') {
                        payload.data = dataOrId;
                    } else if (action === 'delete') {
                        payload.id = dataOrId;
                    }
                    
                    const response = await fetch(APPS_SCRIPT_URL, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'text/plain;charset=utf-8'
                        },
                        body: JSON.stringify(payload)
                    });
                    return await response.json();
                } catch (err) {
                    console.error("Apps Script API Error:", err);
                    throw err;
                }
            };

            // 2. Initial Load from Google Sheets Web App (Merge with Local Storage)
            useEffect(() => {
                const loadDataFromCloud = async () => {
                    if (!APPS_SCRIPT_URL || !isOnline) return;
                    try {
                        // Fetch Teachers
                        const resTeachers = await fetch(`${APPS_SCRIPT_URL}?sheet=teachers`);
                        if (resTeachers.ok) {
                            const cloudTeachers = await resTeachers.json();
                            if (Array.isArray(cloudTeachers) && cloudTeachers.length > 0) {
                                const parsedTeachers = cloudTeachers.map(t => ({
                                    ...t,
                                    id: parseInt(t.id)
                                }));
                                setTeachers(parsedTeachers);
                                localStorage.setItem('school_leave_teachers', JSON.stringify(parsedTeachers));
                            }
                        }
                        
                        // Fetch Leave Records
                        const resRecords = await fetch(`${APPS_SCRIPT_URL}?sheet=leave_records`);
                        if (resRecords.ok) {
                            const cloudRecords = await resRecords.json();
                            if (Array.isArray(cloudRecords)) {
                                const parsedCloud = cloudRecords.map(r => ({
                                    ...r,
                                    userId: parseInt(r.userId),
                                    days: parseFloat(r.days),
                                    timestamp: parseInt(r.timestamp) || Date.now(),
                                    synced: true
                                }));
                                
                                setRecords(prev => {
                                    const mergedMap = new Map(prev.map(r => [r.id, r]));
                                    parsedCloud.forEach(c => {
                                        const local = mergedMap.get(c.id);
                                        if (!local || local.synced !== false) {
                                            mergedMap.set(c.id, c);
                                        }
                                    });
                                    const merged = Array.from(mergedMap.values());
                                    merged.sort((a, b) => b.timestamp - a.timestamp);
                                    localStorage.setItem('school_leave_records', JSON.stringify(merged));
                                    return merged;
                                });
                            }
                        }
                    } catch (e) {
                        console.error("Cloud initial load failed:", e);
                    }
                };
                
                loadDataFromCloud();
            }, [isOnline]);

            // 3. Periodic Background Sync (Push local offline changes to Google Sheets)
            useEffect(() => {
                if (!APPS_SCRIPT_URL || !isOnline) return;
                
                const pushOfflineChanges = async () => {
                    // Sync Teachers
                    const unsyncedTeachers = teachersRef.current.filter(t => t.synced === false);
                    for (const teacher of unsyncedTeachers) {
                        try {
                            const { synced, ...cleanData } = teacher;
                            const res = await callAppsScript("save", "teachers", cleanData);
                            if (res && res.success) {
                                setTeachers(prev => {
                                    const updated = prev.map(t => t.id === teacher.id ? { ...t, synced: true } : t);
                                    localStorage.setItem('school_leave_teachers', JSON.stringify(updated));
                                    return updated;
                                });
                            }
                        } catch (e) {
                            console.error("Failed to sync teacher to cloud:", teacher, e);
                        }
                    }

                    // Sync Leave Records
                    const unsyncedRecords = recordsRef.current.filter(r => r.synced === false);
                    if (unsyncedRecords.length === 0) return;
                    
                    console.log(`Syncing ${unsyncedRecords.length} offline records to Google Sheets...`);
                    let syncSuccessCount = 0;
                    
                    for (const rec of unsyncedRecords) {
                        try {
                            const { synced, ...cleanData } = rec;
                            const res = await callAppsScript("save", "leave_records", cleanData);
                            if (res && res.success) {
                                syncSuccessCount++;
                                setRecords(prev => {
                                    const updated = prev.map(r => r.id === rec.id ? { ...r, synced: true } : r);
                                    localStorage.setItem('school_leave_records', JSON.stringify(updated));
                                    return updated;
                                });
                            }
                        } catch (e) {
                            console.error("Failed to sync record to cloud:", rec, e);
                        }
                    }
                    
                    if (syncSuccessCount > 0) {
                        showAlert(`ซิงก์ข้อมูลออฟไลน์ ${syncSuccessCount} รายการขึ้น Google Sheets เรียบร้อยแล้วค่ะ`, "success");
                    }
                };

                const interval = setInterval(pushOfflineChanges, 15000);
                return () => clearInterval(interval);
            }, [isOnline]);

            const showAlert = (text, type = 'success') => {
                setAlertMsg({ text, type });
                setTimeout(() => setAlertMsg({ text: '', type: '' }), 4000);
            };

            // Calculate leave days between startDate and endDate with full validations
            const calculateDays = (start, end) => {
                if (!start || !end) return 0;
                try {
                    const sParts = start.split('-');
                    const eParts = end.split('-');
                    if (sParts.length !== 3 || eParts.length !== 3) return 0;
                    
                    // Convert to CE if year is in BE (> 2400)
                    const sYear = parseInt(sParts[0]) > 2400 ? parseInt(sParts[0]) - 543 : parseInt(sParts[0]);
                    const eYear = parseInt(eParts[0]) > 2400 ? parseInt(eParts[0]) - 543 : parseInt(eParts[0]);

                    const sDate = new Date(sYear, parseInt(sParts[1]) - 1, parseInt(sParts[2]));
                    const eDate = new Date(eYear, parseInt(eParts[1]) - 1, parseInt(eParts[2]));
                    
                    if (isNaN(sDate.getTime()) || isNaN(eDate.getTime())) return 0;
                    if (eDate < sDate) return -1; // Negative value indicates end before start
                    
                    const diffTime = eDate - sDate;
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
                    return Math.max(diffDays, 0);
                } catch (e) {
                    return 0;
                }
            };

            // Form Start/End Dates auto calculation
            const currentDaysCount = useMemo(() => {
                return calculateDays(formData.startDate, formData.endDate);
            }, [formData.startDate, formData.endDate]);

            // Submit Record
            const handleRecordSubmit = async (e) => {
                e.preventDefault();
                if (!formData.userId) {
                    showAlert("กรุณาเลือกรายชื่อครูผู้ลาด้วยค่ะ", "error");
                    return;
                }
                
                if (currentDaysCount <= 0) {
                    if (currentDaysCount === -1) {
                        showAlert("วันที่สิ้นสุดต้องอยู่หลังวันที่เริ่มต้นค่ะ", "error");
                    } else {
                        showAlert("ช่วงวันที่ลาไม่ถูกต้อง กรุณาตรวจสอบวันที่ค่ะ", "error");
                    }
                    return;
                }

                setIsSubmitting(true);
                const recordId = editMode ? formData.id : 'rec_' + Date.now();
                
                // Format dates to BE structure (YYYY-MM-DD where YYYY is BE)
                const toBE = (dateStr) => {
                    if (!dateStr) return '';
                    const parts = dateStr.split('-');
                    if (parseInt(parts[0]) < 2400) {
                        return `${parseInt(parts[0]) + 543}-${parts[1]}-${parts[2]}`;
                    }
                    return dateStr;
                };

                const recordData = {
                    userId: parseInt(formData.userId),
                    type: formData.type,
                    startDate: toBE(formData.startDate),
                    endDate: toBE(formData.endDate),
                    days: currentDaysCount,
                    reason: formData.reason || '-',
                    substitute: formData.substitute || '-',
                    status: formData.status,
                    timestamp: editMode ? formData.timestamp : Date.now()
                };

                // Save locally first
                let parsedR = [...recordsRef.current];
                if (editMode) {
                    parsedR = parsedR.map(r => r.id === recordId ? { ...recordData, id: recordId, synced: false } : r);
                } else {
                    parsedR.push({ ...recordData, id: recordId, synced: false });
                }
                
                localStorage.setItem('school_leave_records', JSON.stringify(parsedR));
                setRecords(parsedR);

                // Push to Google Sheets if online and URL configured
                if (APPS_SCRIPT_URL && isOnline) {
                    try {
                        const res = await callAppsScript("save", "leave_records", { ...recordData, id: recordId });
                        if (res && res.success) {
                            const updatedRecords = parsedR.map(r => r.id === recordId ? { ...r, synced: true } : r);
                            localStorage.setItem('school_leave_records', JSON.stringify(updatedRecords));
                            setRecords(updatedRecords);
                            showAlert(editMode ? "แก้ไขประวัติการลาสำเร็จและซิงก์ขึ้น Google Sheets แล้วค่ะ" : "บันทึกใบลาสำเร็จและซิงก์ขึ้น Google Sheets แล้วค่ะ");
                        } else {
                            throw new Error(res.error || "Unknown error");
                        }
                    } catch (err) {
                        console.error("Apps Script Save Fail:", err);
                        showAlert(editMode ? "บันทึกแก้ไขในเครื่องสำเร็จ (จะซิงก์ข้อมูลคลาวด์ทีหลังเมื่อพร้อม)" : "บันทึกสำเร็จลงเครื่อง (จะซิงก์ข้อมูลคลาวด์ทีหลังเมื่อพร้อม)", "warning");
                    }
                } else {
                    showAlert(editMode ? "แก้ไขสำเร็จในโหมดออฟไลน์แล้วค่ะ" : "บันทึกใบลาในโหมดออฟไลน์เรียบร้อยแล้วค่ะ", "warning");
                }

                // Reset form
                setFormData({
                    id: '',
                    userId: '',
                    type: 'ลากิจ',
                    startDate: '',
                    endDate: '',
                    reason: '',
                    substitute: '',
                    status: 'approved'
                });
                setEditMode(false);
                setIsSubmitting(false);
                setActiveTab('history');
            };

            // Set Form for Edit
            const startEditRecord = (rec) => {
                const toCE = (dateStr) => {
                    if (!dateStr) return '';
                    const parts = dateStr.split('-');
                    if (parseInt(parts[0]) > 2400) {
                        return `${parseInt(parts[0]) - 543}-${parts[1]}-${parts[2]}`;
                    }
                    return dateStr;
                };

                setFormData({
                    id: rec.id,
                    userId: rec.userId,
                    type: rec.type,
                    startDate: toCE(rec.startDate),
                    endDate: toCE(rec.endDate),
                    reason: rec.reason,
                    substitute: rec.substitute,
                    status: rec.status,
                    timestamp: rec.timestamp
                });
                setEditMode(true);
                setActiveTab('request');
            };

            // Trigger Delete Confirm Modal
            const confirmDelete = (type, id) => {
                setDeleteTarget({ type, id });
            };

            // Execute Delete
            const executeDelete = async () => {
                if (!deleteTarget) return;

                const { type, id } = deleteTarget;

                if (type === 'record') {
                    const updatedR = recordsRef.current.filter(r => r.id !== id);
                    setRecords(updatedR);
                    localStorage.setItem('school_leave_records', JSON.stringify(updatedR));

                    if (APPS_SCRIPT_URL && isOnline) {
                        try {
                            const res = await callAppsScript("delete", "leave_records", id);
                            if (res && res.success) {
                                showAlert("ลบประวัติการลาออกจาก Google Sheets เรียบร้อยแล้วค่ะ");
                            } else {
                                throw new Error(res.error || "Unknown error");
                            }
                        } catch (err) {
                            console.error("Apps Script Delete Fail:", err);
                            showAlert("ลบรายการในเครื่องเรียบร้อยแล้ว (การลบในคลาวด์ไม่สำเร็จ)", "warning");
                        }
                    } else {
                        showAlert("ลบข้อมูลสำเร็จในเครื่องแล้วค่ะ (โหมดออฟไลน์)", "warning");
                    }
                } else if (type === 'teacher') {
                    const updatedT = teachersRef.current.filter(t => t.id !== id);
                    setTeachers(updatedT);
                    localStorage.setItem('school_leave_teachers', JSON.stringify(updatedT));

                    if (APPS_SCRIPT_URL && isOnline) {
                        try {
                            const res = await callAppsScript("delete", "teachers", id);
                            if (res && res.success) {
                                showAlert("ลบรายชื่อบุคลากรออกจาก Google Sheets สำเร็จแล้วค่ะ");
                            } else {
                                throw new Error(res.error || "Unknown error");
                            }
                        } catch (err) {
                            console.error("Apps Script Delete Teacher Fail:", err);
                            showAlert("ลบรายชื่อในเครื่องสำเร็จแล้วค่ะ (การลบในคลาวด์ไม่สำเร็จ)", "warning");
                        }
                    } else {
                        showAlert("ลบรายชื่อในเครื่องสำเร็จ (โหมดออฟไลน์)", "warning");
                    }
                }

                setDeleteTarget(null);
            };

            // Submit Teacher Form
            const handleTeacherSubmit = async (e) => {
                e.preventDefault();
                if (!teacherForm.name || !teacherForm.pos) {
                    showAlert("กรุณากรอกข้อมูลครูให้ครบถ้วนด้วยค่ะ", "error");
                    return;
                }

                const nextId = teacherForm.id || (teachersRef.current.length > 0 ? Math.max(...teachersRef.current.map(t => t.id)) + 1 : 1);
                const teacherData = {
                    id: parseInt(nextId),
                    name: teacherForm.name,
                    pos: teacherForm.pos,
                    role: 'user'
                };

                let updatedT = [...teachersRef.current];
                if (teacherForm.id) {
                    updatedT = updatedT.map(t => t.id === teacherForm.id ? { ...teacherData, synced: false } : t);
                } else {
                    updatedT.push({ ...teacherData, synced: false });
                }

                setTeachers(updatedT);
                localStorage.setItem('school_leave_teachers', JSON.stringify(updatedT));

                if (APPS_SCRIPT_URL && isOnline) {
                    try {
                        const res = await callAppsScript("save", "teachers", teacherData);
                        if (res && res.success) {
                            const updated = updatedT.map(t => t.id === nextId ? { ...t, synced: true } : t);
                            setTeachers(updated);
                            localStorage.setItem('school_leave_teachers', JSON.stringify(updated));
                            showAlert(teacherForm.id ? "แก้ไขข้อมูลครูสำเร็จและซิงก์ขึ้น Google Sheets แล้วค่ะ" : "เพิ่มรายชื่อครูใหม่สำเร็จและซิงก์ขึ้น Google Sheets แล้วค่ะ");
                        } else {
                            throw new Error(res.error || "Unknown error");
                        }
                    } catch (err) {
                        console.error("Apps Script Save Teacher Fail:", err);
                        showAlert("บันทึกข้อมูลครูลงเครื่องสำเร็จแล้วค่ะ (จะซิงก์คลาวด์ทีหลังเมื่อพร้อม)", "warning");
                    }
                } else {
                    showAlert("บันทึกข้อมูลครูสำเร็จ (โหมดออฟไลน์)", "warning");
                }

                setTeacherForm({ id: '', name: '', pos: '' });
                setShowTeacherModal(false);
            };

            // Format date for Thai layout (DD/MM/BE)
            const formatDateBE = (dateStr) => {
                if (!dateStr) return '-';
                const parts = dateStr.split('-');
                if (parts.length !== 3) return dateStr;
                const year = parseInt(parts[0]);
                const yearBE = year < 2400 ? year + 543 : year;
                return `${parts[2]}/${parts[1]}/${yearBE}`;
            };

            // Export to Excel using SheetJS with current parameters
            const handleExportExcel = () => {
                const activeRecords = filteredRecords;
                const activeSummary = globalSummary;

                if (activeRecords.length === 0) {
                    showAlert("ไม่มีข้อมูลการลาให้ส่งออกรายงานค่ะ", "error");
                    return;
                }

                // 1. Prepare Data for Sheet 1: รายการขอลาทั้งหมด
                const rawSheetData = activeRecords.map((r, index) => {
                    const teacher = teachers.find(t => t.id === r.userId);
                    return {
                        'ลำดับ': index + 1,
                        'ชื่อ-นามสกุล': teacher ? teacher.name : `ไม่ระบุชื่อ (ID: ${r.userId})`,
                        'ตำแหน่ง': teacher ? teacher.pos : 'ไม่ระบุตำแหน่ง',
                        'ประเภทการลา': r.type,
                        'วันที่เริ่ม': formatDateBE(r.startDate),
                        'วันที่สิ้นสุด': formatDateBE(r.endDate),
                        'จำนวนวันลา': r.days,
                        'เหตุผลความจำเป็น': r.reason,
                        'ผู้ปฏิบัติหน้าที่แทน': r.substitute,
                        'สถานะ': r.status === 'approved' ? 'อนุมัติแล้ว' : 'รอดำเนินการ'
                    };
                });

                // 2. Prepare Data for Sheet 2: สรุปยอดสะสมรายบุคคล
                const summarySheetData = activeSummary.map((t, index) => {
                    return {
                        'ลำดับ': index + 1,
                        'ชื่อ-นามสกุล': t.name,
                        'ตำแหน่ง': t.pos,
                        'ลาป่วย (วัน)': t.sick.days,
                        'ลาป่วย (ครั้ง)': t.sick.times,
                        'ลากิจ (วัน)': t.personal.days,
                        'ลากิจ (ครั้ง)': t.personal.times,
                        'ลาบวช/ลาอื่นๆ (วัน)': t.others.days,
                        'ลาบวช/ลาอื่นๆ (ครั้ง)': t.others.times,
                        'รวมวันลาทั้งหมด': t.total.days,
                        'รวมจำนวนครั้งที่ลา': t.total.times
                    };
                });

                // Add Sum totals at the end of summary sheet
                const totalSickDays = activeSummary.reduce((sum, t) => sum + t.sick.days, 0);
                const totalSickTimes = activeSummary.reduce((sum, t) => sum + t.sick.times, 0);
                const totalPersonalDays = activeSummary.reduce((sum, t) => sum + t.personal.days, 0);
                const totalPersonalTimes = activeSummary.reduce((sum, t) => sum + t.personal.times, 0);
                const totalOtherDays = activeSummary.reduce((sum, t) => sum + t.others.days, 0);
                const totalOtherTimes = activeSummary.reduce((sum, t) => sum + t.others.times, 0);
                const totalAllDays = activeSummary.reduce((sum, t) => sum + t.total.days, 0);
                const totalAllTimes = activeSummary.reduce((sum, t) => sum + t.total.times, 0);

                summarySheetData.push({
                    'ลำดับ': '',
                    'ชื่อ-นามสกุล': 'ยอดรวมทั้งสิ้น',
                    'ตำแหน่ง': '',
                    'ลาป่วย (วัน)': totalSickDays,
                    'ลาป่วย (ครั้ง)': totalSickTimes,
                    'ลากิจ (วัน)': totalPersonalDays,
                    'ลากิจ (ครั้ง)': totalPersonalTimes,
                    'ลาบวช/ลาอื่นๆ (วัน)': totalOtherDays,
                    'ลาบวช/ลาอื่นๆ (ครั้ง)': totalOtherTimes,
                    'รวมวันลาทั้งหมด': totalAllDays,
                    'รวมจำนวนครั้งที่ลา': totalAllTimes
                });

                const wb = XLSX.utils.book_new();
                
                // Create sheet 1
                const wsRaw = XLSX.utils.json_to_sheet(rawSheetData);
                const wscolsRaw = [
                    {wch: 6},  // ลำดับ
                    {wch: 25}, // ชื่อ-นามสกุล
                    {wch: 18}, // ตำแหน่ง
                    {wch: 12}, // ประเภทการลา
                    {wch: 12}, // วันที่เริ่ม
                    {wch: 12}, // วันที่สิ้นสุด
                    {wch: 12}, // จำนวนวันลา
                    {wch: 25}, // เหตุผลความจำเป็น
                    {wch: 25}, // ผู้ปฏิบัติหน้าที่แทน
                    {wch: 12}  // สถานะ
                ];
                wsRaw['!cols'] = wscolsRaw;
                XLSX.utils.book_append_sheet(wb, wsRaw, `ประวัติการลาปี ${filterYear}`);

                // Create sheet 2
                const wsSum = XLSX.utils.json_to_sheet(summarySheetData);
                const wscolsSum = [
                    {wch: 6},  // ลำดับ
                    {wch: 25}, // ชื่อ-นามสกุล
                    {wch: 18}, // ตำแหน่ง
                    {wch: 14}, // ลาป่วยวัน
                    {wch: 14}, // ลาป่วยครั้ง
                    {wch: 14}, // ลากิจวัน
                    {wch: 14}, // ลากิจครั้ง
                    {wch: 20}, // ลาอื่นๆวัน
                    {wch: 20}, // ลาอื่นๆครั้ง
                    {wch: 18}, // รวมวัน
                    {wch: 18}  // รวมครั้ง
                ];
                wsSum['!cols'] = wscolsSum;
                XLSX.utils.book_append_sheet(wb, wsSum, "สรุปยอดสะสมเสนอเซ็น");

                // Generate filename: ข้อมูลการลา_ปี_2569.xlsx
                const filename = `รายงานการลาครู_หนองใส_${filterYear || '2569'}.xlsx`;
                XLSX.writeFile(wb, filename);
                showAlert("ดาวน์โหลดรายงาน Excel สำเร็จแล้วค่ะ");
            };

            // Filtered records based on query filters
            const filteredRecords = useMemo(() => {
                return records.filter(r => {
                    const teacher = teachers.find(t => t.id === r.userId);
                    const teacherName = teacher ? teacher.name : '';
                    
                    const matchTeacher = filterTeacher === '' || teacherName.includes(filterTeacher);
                    const matchType = filterType === 'all' || r.type === filterType;
                    const matchYear = filterYear === 'all' || (r.startDate && r.startDate.startsWith(filterYear));
                    
                    return matchTeacher && matchType && matchYear;
                }).sort((a, b) => b.timestamp - a.timestamp);
            }, [records, teachers, filterTeacher, filterType, filterYear]);

            // Summary calculations for Sheet 2 / Tab 4
            const globalSummary = useMemo(() => {
                return teachers.map(t => {
                    const approvedR = records.filter(r => r.userId === t.id && r.status === 'approved' && (filterYear === 'all' || (r.startDate && r.startDate.startsWith(filterYear))));
                    
                    const calcType = (type) => {
                        const typeRecords = approvedR.filter(r => r.type === type);
                        const days = typeRecords.reduce((sum, item) => sum + item.days, 0);
                        return { days, times: typeRecords.length };
                    };

                    const sick = calcType('ลาป่วย');
                    const personal = calcType('ลากิจ');
                    
                    const otherRecords = approvedR.filter(r => r.type !== 'ลาป่วย' && r.type !== 'ลากิจ');
                    const otherDays = otherRecords.reduce((sum, item) => sum + item.days, 0);
                    const otherTimes = otherRecords.length;

                    return {
                        ...t,
                        sick,
                        personal,
                        others: { days: otherDays, times: otherTimes },
                        total: {
                            days: sick.days + personal.days + otherDays,
                            times: sick.times + personal.times + otherTimes
                        }
                    };
                }).sort((a, b) => a.id - b.id);
            }, [records, teachers, filterYear]);

            // Get target item details for delete confirmation modal (DeepSeek suggestion)
            const targetRecord = useMemo(() => {
                if (deleteTarget && deleteTarget.type === 'record') {
                    return records.find(r => r.id === deleteTarget.id);
                }
                return null;
            }, [deleteTarget, records]);

            const targetTeacher = useMemo(() => {
                if (deleteTarget) {
                    if (deleteTarget.type === 'teacher') {
                        return teachers.find(t => t.id === deleteTarget.id);
                    } else if (deleteTarget.type === 'record' && targetRecord) {
                        return teachers.find(t => t.id === targetRecord.userId);
                    }
                }
                return null;
            }, [deleteTarget, targetRecord, teachers]);

            return (
                <div className="min-h-screen md:h-screen md:overflow-hidden flex flex-col md:flex-row bg-slate-100">
                    
                    {/* Floating Alert */}
                    {alertMsg.text && (
                        <div className="fixed top-5 right-5 z-[300] bg-slate-900/90 text-white rounded-2xl p-4 shadow-2xl flex items-center gap-3 animate-fade-in border border-slate-700">
                            <Icon name={alertMsg.type === 'error' ? 'alert-circle' : alertMsg.type === 'warning' ? 'alert-triangle' : 'check-circle'} 
                                  className={alertMsg.type === 'error' ? 'text-red-500' : alertMsg.type === 'warning' ? 'text-amber-500' : 'text-emerald-500'} />
                            <span className="font-semibold text-sm">{alertMsg.text}</span>
                        </div>
                    )}

                    {/* Delete Confirm Modal */}
                    {deleteTarget && (
                        <div className="fixed inset-0 bg-slate-955/70 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
                            <div className="bg-white rounded-3xl p-8 max-w-sm w-full shadow-2xl border border-slate-100 text-center animate-fade-in">
                                <div className="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <Icon name="trash-2" size={32} />
                                </div>
                                <h3 className="text-xl font-bold text-slate-900 mb-2">ยืนยันการลบข้อมูล?</h3>
                                <p className="text-slate-500 text-sm mb-6 leading-relaxed">
                                    {deleteTarget.type === 'record' 
                                        ? `คุณต้องการลบประวัติการลาของ ${targetTeacher ? targetTeacher.name : 'ไม่ระบุชื่อ'} (${targetRecord ? `${targetRecord.type} วันที่ ${formatDateBE(targetRecord.startDate)}` : ''}) ใช่หรือไม่? ข้อมูลจะไม่สามารถกู้คืนกลับมาได้ค่ะ`
                                        : `คุณต้องการลบชื่อของ ${targetTeacher ? targetTeacher.name : ''} (${targetTeacher ? targetTeacher.pos : ''}) ออกจากระบบ? การลบชื่อครูจะส่งผลต่อการกรอกใบลาในอนาคตค่ะ`
                                    }
                                </p>
                                <div className="flex gap-4">
                                    <button onClick={() => setDeleteTarget(null)} className="flex-1 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-xl font-bold text-sm transition-all">ยกเลิก</button>
                                    <button onClick={executeDelete} className="flex-1 py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold text-sm shadow-lg shadow-red-200 transition-all">ลบข้อมูล</button>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Add/Edit Teacher Modal */}
                    {showTeacherModal && (
                        <div className="fixed inset-0 bg-slate-955/70 backdrop-blur-sm z-[200] flex items-center justify-center p-4">
                            <div className="bg-white rounded-3xl p-8 max-w-md w-full shadow-2xl border border-slate-100 animate-fade-in">
                                <div className="flex justify-between items-center mb-6">
                                    <h3 className="text-lg font-bold text-slate-900 flex items-center gap-2">
                                        <Icon name="user-plus" className="text-blue-600" />
                                        {teacherForm.id ? "แก้ไขข้อมูลบุคลากร" : "เพิ่มรายชื่อบุคลากรใหม่"}
                                    </h3>
                                    <button onClick={() => setShowTeacherModal(false)} className="text-slate-400 hover:text-slate-600">
                                        <Icon name="x" size={24} />
                                    </button>
                                </div>
                                <form onSubmit={handleTeacherSubmit} className="space-y-4">
                                    <div className="space-y-1">
                                        <label className="text-xs text-slate-400 uppercase tracking-wider font-semibold">ชื่อ-นามสกุล</label>
                                        <input type="text" value={teacherForm.name} onChange={e => setTeacherForm({...teacherForm, name: e.target.value})} placeholder="ป้อนชื่อและนามสกุล" required className="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:border-blue-500 focus:bg-white outline-none transition-all font-semibold" />
                                    </div>
                                    <div className="space-y-1">
                                        <label className="text-xs text-slate-400 uppercase tracking-wider font-semibold">ตำแหน่ง</label>
                                        <input type="text" value={teacherForm.pos} onChange={e => setTeacherForm({...teacherForm, pos: e.target.value})} placeholder="ตัวอย่างเช่น ครู คศ.3, ครูผู้ช่วย" required className="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:border-blue-500 focus:bg-white outline-none transition-all font-semibold" />
                                    </div>
                                    <button type="submit" className="w-full py-4 bg-blue-700 hover:bg-blue-800 text-white rounded-2xl font-bold shadow-lg shadow-blue-200 transition-all">
                                        {teacherForm.id ? "บันทึกการแก้ไข" : "เพิ่มรายชื่อลงระบบ"}
                                    </button>
                                </form>
                            </div>
                        </div>
                    )}

                    {/* Sidebar Navigation */}
                    <aside className="w-full md:w-72 bg-slate-900 text-white flex flex-col h-auto md:h-screen sticky top-0 z-50">
