                                                                    <Icon name="pencil" size={16} />
                                                                </button>
                                                                <button onClick={() => confirmDelete('teacher', t.id)} className="p-1.5 bg-red-50 hover:bg-red-100 text-red-600 rounded-lg transition-all flex items-center justify-center min-w-[32px] min-h-[32px]" title="ลบ">
