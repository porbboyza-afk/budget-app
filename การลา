<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบจัดการการลา - โรงเรียนหนองใสพรเจริญวิทยา</title>
    <!-- 1. Library Setup -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@100;400;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- 2. Firebase SDK Compat -->
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>

    <style>
        body { font-family: 'Sarabun', sans-serif; background-color: #cbd5e1; }
        .teacher-card { transition: all 0.25s ease-in-out; border: 3px solid #94a3b8; background-color: white; cursor: pointer; }
        .teacher-card:hover { transform: translateY(-5px); border-color: #2563eb; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15); }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 10px; }
        
        /* เพิ่มเพื่อป้องกันตารางล้นจอในมือถือ */
        .table-responsive-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useMemo, useEffect, useRef } = React;

        // --- Firebase Config ---
        const firebaseConfig = {
            apiKey: "AIzaSyAUryuhFy1uunyyRXmFJsRARkUSbTT68FA",
            authDomain: "schoolleave-669a7.firebaseapp.com",
            projectId: "schoolleave-669a7",
            storageBucket: "schoolleave-669a7.firebasestorage.app",
            messagingSenderId: "850104833391",
            appId: "1:850104833391:web:b9bb828d6625778691c49a",
            measurementId: "G-3YMMBD7P6P"
        };

        const teachersList = [
            { id: 1, name: 'นายชุมพร กรุณานำ', pos: 'ผอ.รร', role: 'admin' },
            { id: 2, name: 'นางสาวสราลักษณ์ แก้วโสภา', pos: 'ครู คศ.3', role: 'user' },
            { id: 3, name: 'นางจิราพร ไชยมาศ', pos: 'ครู คศ.3', role: 'user' },
            { id: 4, name: 'นางสาวธีมาพร นามบุรี', pos: 'ครู คศ.1', role: 'user' },
            { id: 5, name: 'นางวาสนา สุขขิน', pos: 'ครู คศ.2', role: 'user' },
            { id: 6, name: 'นางสาวยุวดี จิตรปรีดา', pos: 'ครู คศ.3', role: 'user' },
            { id: 7, name: 'นายครองศักดิ์ ขาวขันธ์', pos: 'ครู คศ.3', role: 'user' },
            { id: 8, name: 'นายวิทธวัช ตาลมงคล', pos: 'ครู คศ.1', role: 'user' },
            { id: 9, name: 'นายเอกวิทย์ ฝุ่นเงิน', pos: 'ครู คศ.2', role: 'user' },
            { id: 10, name: 'นายราชาชัย รุ่งโรจน์', pos: 'ครู คศ.2', role: 'user' },
            { id: 11, name: 'นางสาวนิราณี รักษาวงศ์', pos: 'ครูผู้ช่วย', role: 'user' },
            { id: 12, name: 'นางนวลมณี สมประสงค์', pos: 'ครู คศ.3', role: 'user' },
            { id: 13, name: 'นางสาวศิริลักษณ์ อัคนิจ', pos: 'ครู คศ.1', role: 'user' },
            { id: 14, name: 'นายสุรศักดิ์ อุ่นแก้ว', pos: 'ครู คศ.1', role: 'user' },
            { id: 15, name: 'นายเกรียงศักดิ์ สร้อยกลางเมือง', pos: 'ครู คศ.1', role: 'user' },
            { id: 16, name: 'นางสาวนัฐธิยา จันทร์ศรีโคตร', pos: 'ครูอัตราจ้าง', role: 'user' },
            { id: 17, name: 'นายปรัชญา ศรีจันทร์', pos: 'จนท.ธุรการ', role: 'user', isSecretary: true },
        ];

        const Icon = ({ name, size = 24, className = "" }) => {
            const ref = useRef(null);
            useEffect(() => {
                if (window.lucide && window.lucide.icons[name] && ref.current) {
                    ref.current.innerHTML = window.lucide.icons[name].toSvg({ width: size, height: size, class: className });
                }
            }, [name, size, className]);
            return <span ref={ref} className={`inline-flex items-center justify-center ${className}`} style={{ minWidth: size, minHeight: size }}></span>;
        };

        const App = () => {
            const [db, setDb] = useState(null);
            const [isOnline, setIsOnline] = useState(false);
            const [requests, setRequests] = useState([]);
            const appId = 'school-leave-v4-production';

            const [currentPage, setCurrentPage] = useState('selection'); 
            const [selectedTeacher, setSelectedTeacher] = useState(null);
            const [showLoginModal, setShowLoginModal] = useState(false);
            const [passwordInput, setPasswordInput] = useState('');
            const [activeTab, setActiveTab] = useState('dashboard');
            const [isSuccessModalOpen, setIsSuccessModalOpen] = useState(false);
            const [isSubmitting, setIsSubmitting] = useState(false);
            const [isAuthorizedMaster, setIsAuthorizedMaster] = useState(false);
            const [requestToDelete, setRequestToDelete] = useState(null);
            const [showResetModal, setShowResetModal] = useState(false);
            const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);

            const [formData, setFormData] = useState({ type: 'ลากิจ', startDate: '', endDate: '', reason: '', substitute: '' });

            // Initialize Firebase Compat
            useEffect(() => {
                if (!firebase.apps.length) {
                    firebase.initializeApp(firebaseConfig);
                }
                const firestore = firebase.firestore();
                setDb(firestore);

                firebase.auth().signInAnonymously().then(() => {
                    setIsOnline(true);
                }).catch(err => console.error("Firebase Auth Fail", err));
            }, []);

            // Realtime Sync
            useEffect(() => {
                if (!db || !isOnline) return;
                const unsub = db.collection('artifacts').doc(appId).collection('public_data')
                    .onSnapshot((snaps) => {
                        const data = snaps.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                        setRequests(data);
                    }, (err) => console.log("Waiting for Rules..."));
                return () => unsub();
            }, [db, isOnline]);

            const isAdmin = selectedTeacher?.role === 'admin';
            const isMaster = isAuthorizedMaster;
            const currentYearBE = 2569;

            const userRequests = useMemo(() => selectedTeacher ? requests.filter(r => r.userId === selectedTeacher.id) : [], [requests, selectedTeacher]);
            
            const stats = useMemo(() => {
                const calc = (type) => ({ 
                    used: userRequests.filter(r => r.type === type && r.status === 'approved').length, 
                    pending: userRequests.filter(r => r.type === type && r.status === 'pending').length 
                });
                return { personal: calc('ลากิจ'), sick: calc('ลาป่วย'), maternity: calc('ลาคลอดบุตร'), paternity: calc('ลาช่วยภรรยา'), ordination: calc('ลาอุปสมบท') };
            }, [userRequests]);

            // สถิติสำหรับ ผอ. (รวมทั้งโรงเรียน)
            const globalSummary = useMemo(() => {
                return teachersList.map(t => {
                    const teacherApprovedRequests = requests.filter(r => r.userId === t.id && r.status === 'approved');
                    
                    const calculateStats = (type) => {
                        const typeRequests = teacherApprovedRequests.filter(r => r.type === type);
                        const days = typeRequests.reduce((acc, curr) => {
                            // เพิ่ม Safety Check เพื่อแก้ปัญหา "หน้าจอขาว" เวลาข้อมูลในฐานข้อมูลแหว่ง
                            if (!curr.startDate || !curr.endDate) return acc;
                            
                            const start = new Date(curr.startDate.replace(/(\d{4})/, (m) => parseInt(m) - 543));
                            const end = new Date(curr.endDate.replace(/(\d{4})/, (m) => parseInt(m) - 543));
                            const diffTime = Math.abs(end - start);
                            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
                            return acc + (isNaN(diffDays) ? 0 : diffDays);
                        }, 0);
                        return { days, times: typeRequests.length };
                    };

                    const sickStats = calculateStats('ลาป่วย');
                    const personalStats = calculateStats('ลากิจ');
                    
                    const maternity = calculateStats('ลาคลอดบุตร');
                    const paternity = calculateStats('ลาช่วยภรรยาคลอดบุตร');
                    const ordination = calculateStats('ลาอุปสมบท');

                    const otherDays = maternity.days + paternity.days + ordination.days;
                    const otherTimes = maternity.times + paternity.times + ordination.times;

                    return {
                        ...t,
                        sick: sickStats,
                        personal: personalStats,
                        others: { days: otherDays, times: otherTimes },
                        total: { 
                            days: sickStats.days + personalStats.days + otherDays, 
                            times: sickStats.times + personalStats.times + otherTimes 
                        }
                    };
                }).filter(t => t.role !== 'admin');
            }, [requests]);

            const formatDateBE = (dateStr) => {
                if (!dateStr) return '';
                const parts = dateStr.split('-');
                if (parts.length !== 3) return dateStr;
                const year = parseInt(parts[0]);
                const yearBE = year < 2400 ? year + 543 : year;
                return `${parts[2]}/${parts[1]}/${yearBE}`;
            };

            const handleLoginSubmit = (e) => {
                e.preventDefault();
                const isMasterPass = passwordInput === '0814' && selectedTeacher.isSecretary;
                if (isMasterPass || passwordInput === '1234') {
                    setIsAuthorizedMaster(isMasterPass);
                    setCurrentPage('app');
                    setShowLoginModal(false);
                    setActiveTab(isMasterPass ? 'summary' : (selectedTeacher.role === 'admin' ? 'admin' : 'dashboard'));
                    setPasswordInput('');
                } else { alert("รหัสผ่านไม่ถูกต้อง"); }
            };

            const handleLogoutButton = () => {
                setSelectedTeacher(null);
                setCurrentPage('selection');
                setShowLoginModal(false);
                setIsAuthorizedMaster(false);
                setActiveTab('dashboard');
                setPasswordInput('');
                setIsMobileMenuOpen(false);
            };

            const handleSubmitRequest = async (e) => {
                e.preventDefault();
                setIsSubmitting(true);
                const cv = (val) => {
                    const p = val.split('-');
                    return `${parseInt(p[0]) + 543}-${p[1]}-${p[2]}`;
                };

                const newReq = {
                    userId: selectedTeacher.id,
                    ...formData,
                    startDate: cv(formData.startDate),
                    endDate: cv(formData.endDate),
                    status: 'pending',
                    timestamp: Date.now()
                };

                try {
                    await db.collection('artifacts').doc(appId).collection('public_data').add(newReq);
                    setIsSuccessModalOpen(true);
                    setActiveTab('history');
                    setFormData({ type: 'ลากิจ', startDate: '', endDate: '', reason: '', substitute: '' });
                } catch (err) { alert("Error: " + err.message); }
                finally { setIsSubmitting(false); }
            };

            const handleApprove = async (id, status) => {
                await db.collection('artifacts').doc(appId).collection('public_data').doc(id).update({ status });
            };

            const handleDelete = async (id) => {
                await db.collection('artifacts').doc(appId).collection('public_data').doc(id).delete();
                setRequestToDelete(null);
            };

            const handleResetAllData = async () => {
                setIsSubmitting(true);
                try {
                    const batch = db.batch();
                    const snaps = await db.collection('artifacts').doc(appId).collection('public_data').get();
                    snaps.forEach(doc => batch.delete(doc.ref));
                    await batch.commit();
                    setShowResetModal(false);
                    alert("ล้างข้อมูลทั้งระบบเรียบร้อยแล้ว");
                } catch (err) { alert("ล้มเหลว: " + err.message); }
                finally { setIsSubmitting(false); }
            };

            const changeTabMobile = (tab) => {
                setActiveTab(tab);
                setIsMobileMenuOpen(false);
            };

            const exportToExcel = () => {
                const headers = ['ลำดับ', 'ชื่อ-นามสกุล', 'ตำแหน่ง', 'ประเภทการลา', 'เริ่มวันที่', 'ถึงวันที่', 'เหตุผล', 'ผู้สอนแทน', 'สถานะ'];
                const rows = requests.map((req, index) => {
                    const t = teachersList.find(x => x.id === req.userId);
                    return [
                        index + 1,
                        t?.name || 'ไม่ระบุ',
                        t?.pos || '-',
                        req.type,
                        formatDateBE(req.startDate),
                        formatDateBE(req.endDate),
                        (req.reason || '').replace(/,/g, ' '),
                        req.substitute || '-',
                        req.status === 'approved' ? 'อนุมัติแล้ว' : req.status === 'pending' ? 'รอดำเนินการ' : 'ถูกปฏิเสธ'
                    ];
                });
                const csvContent = "\uFEFF" + [headers, ...rows].map(e => e.join(",")).join("\n");
                const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement("a");
                link.href = URL.createObjectURL(blob);
                link.download = `รายงานการลา_รร_หนองใส_${currentYearBE}.csv`;
                link.click();
            };

            if (currentPage === 'selection') {
                return (
                    <div className="min-h-screen bg-slate-300 p-4 md:p-12 flex flex-col items-center">
                        {showLoginModal && (
                            <div className="fixed inset-0 bg-slate-900/80 backdrop-blur-md z-[100] flex items-center justify-center p-4">
                                <div className="bg-white rounded-[2rem] shadow-2xl w-full max-w-md p-10 animate-fade-in border-4 border-white text-center">
                                    <Icon name="lock" size={48} className="text-blue-600 mb-4 mx-auto" />
                                    <h3 className="text-2xl font-black text-slate-800 tracking-tight italic uppercase">ยืนยันตัวตน</h3>
                                    <p className="text-blue-600 font-bold mb-8 uppercase text-xs tracking-widest">{selectedTeacher?.name}</p>
                                    <form onSubmit={handleLoginSubmit} className="space-y-6">
                                        <input autoFocus type="password" value={passwordInput} onChange={(e) => setPasswordInput(e.target.value)} placeholder="ป้อนรหัสผ่าน" className="w-full p-4 bg-slate-50 border-2 rounded-2xl text-center text-3xl font-black tracking-widest outline-none focus:ring-4 focus:ring-blue-100" />
                                        <div className="flex gap-4">
                                            <button type="button" onClick={() => setShowLoginModal(false)} className="flex-1 py-4 text-slate-500 font-bold hover:bg-slate-100 rounded-xl transition-all">ยกเลิก</button>
                                            <button type="submit" className="flex-1 bg-blue-700 text-white py-4 rounded-2xl font-black shadow-lg hover:bg-blue-800 transition-all">ตกลง</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        )}
                        <div className="max-w-7xl w-full text-center">
                            <div className="mb-12 inline-block px-10 py-6 bg-white/95 rounded-[2.5rem] border-2 border-slate-400 shadow-2xl animate-fade-in">
                                <h1 className="text-3xl md:text-4xl font-black text-slate-900 uppercase tracking-tighter italic leading-none">ระบบจัดการการลา โรงเรียนหนองใสพรเจริญวิทยา</h1>
                                <p className="text-blue-700 font-bold uppercase tracking-widest text-[10px] mt-2 italic font-black">Leave Online Cloud (พ.ศ. {currentYearBE})</p>
                            </div>
                            <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-4 gap-5 font-black mb-10">
                                {teachersList.map(t => (
                                    <div key={t.id} onClick={() => { setSelectedTeacher(t); setShowLoginModal(true); }} className={`teacher-card p-5 rounded-[1.5rem] shadow-xl text-left flex flex-col justify-between h-40 group ${t.role === 'admin' ? 'border-blue-500' : ''}`}>
                                        <div>
                                            <h3 className="font-extrabold text-slate-900 text-lg leading-tight mb-2 break-words">{t.name}</h3>
                                            <span className={`inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-widest ${t.role === 'admin' ? 'bg-blue-600 text-white' : 'bg-slate-100 text-slate-500'}`}>{t.pos}</span>
                                        </div>
                                        <div className="flex justify-end items-center"><Icon name="chevron-right" className="text-slate-300 group-hover:text-blue-600 transition-colors" /></div>
                                    </div>
                                ))}
                            </div>
                        </div>
                        <div className="mt-auto pt-8 pb-4 text-[10px] text-slate-500 font-bold tracking-widest uppercase">
                            ผู้ออกแบบระบบ: นายปรัชญา ศรีจันทร์
                        </div>
                    </div>
                );
            }

            return (
                <div className="min-h-screen bg-slate-50 flex flex-col md:flex-row antialiased font-black relative overflow-x-hidden">
                    {/* Modals */}
                    {isSuccessModalOpen && (
                        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] flex items-center justify-center p-4">
                            <div className="bg-white rounded-[2.5rem] p-10 shadow-2xl max-w-sm w-full text-center border-4 border-green-50 animate-fade-in font-black">
                                <Icon name="check-circle" size={56} className="text-green-600 mb-6 mx-auto" />
                                <h3 className="text-3xl font-black text-slate-800 mb-2 italic text-center">ส่งใบลาสำเร็จ!</h3>
                                <p className="text-slate-500 font-bold mb-8 italic text-sm text-center">ข้อมูลถูกบันทึกขึ้นคลาวด์แล้ว ข้อมูลจะไม่หายเมื่อรีเฟรชหน้าจอ</p>
                                <button onClick={() => setIsSuccessModalOpen(false)} className="w-full bg-green-600 text-white py-4 rounded-2xl font-black shadow-lg hover:bg-green-700 transition-all">ตกลง</button>
                            </div>
                        </div>
                    )}
                    
                    {showResetModal && (
                        <div className="fixed inset-0 bg-red-900/80 backdrop-blur-lg z-[300] flex items-center justify-center p-4">
                            <div className="bg-white rounded-[2.5rem] p-10 shadow-2xl max-w-md w-full text-center border-4 border-red-100 animate-fade-in font-black">
                                <div className="w-20 h-20 bg-red-100 text-red-600 rounded-full flex items-center justify-center mx-auto mb-6"><Icon name="trash-2" size={48} /></div>
                                <h3 className="text-3xl font-black text-slate-800 mb-2 italic uppercase">ล้างข้อมูลยกเทอม?</h3>
                                <p className="text-slate-600 font-bold mb-8 text-sm leading-relaxed">คำเตือน: ข้อมูลการลาทั้งหมดของบุคลากรทุกคนจะถูกลบทิ้งถาวรจาก Google Cloud เพื่อเริ่มเก็บข้อมูลเทอมใหม่ ไม่สามารถกู้คืนได้</p>
                                <div className="flex flex-col gap-4">
                                    <button disabled={isSubmitting} onClick={handleResetAllData} className="w-full bg-red-600 text-white py-5 rounded-2xl font-black shadow-xl hover:bg-red-700 transition-all flex items-center justify-center gap-3">
                                        {isSubmitting ? <Icon name="loader" className="animate-spin" /> : <Icon name="trash-2" />} ยืนยันลบข้อมูลทั้งหมดถาวร
                                    </button>
                                    <button onClick={() => setShowResetModal(false)} className="w-full py-4 text-slate-400 font-black uppercase tracking-widest text-xs">ยกเลิก</button>
                                </div>
                            </div>
                        </div>
                    )}

                    {requestToDelete && (
                        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[200] flex items-center justify-center p-4">
                            <div className="bg-white rounded-[2.5rem] p-10 shadow-2xl max-w-sm w-full text-center animate-fade-in border-4 border-red-50">
                                <Icon name="alert-triangle" size={56} className="text-red-600 mb-6 mx-auto" />
                                <h3 className="text-2xl font-black text-slate-800 mb-2">ยืนยันการลบ?</h3>
                                <p className="text-slate-500 mb-8 font-bold text-sm leading-relaxed">คุณต้องการลบรายการนี้ออกจากระบบคลาวด์ถาวรใช่หรือไม่</p>
                                <div className="flex gap-4">
                                    <button onClick={() => setRequestToDelete(null)} className="flex-1 py-4 bg-slate-100 font-bold rounded-xl">ยกเลิก</button>
                                    <button onClick={() => handleDelete(requestToDelete)} className="flex-1 py-4 bg-red-600 text-white font-black rounded-xl shadow-lg">ลบข้อมูล</button>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Mobile Header */}
                    <div className="md:hidden bg-blue-900 text-white p-4 flex justify-between items-center sticky top-0 z-40 shadow-md">
                        <div className="font-black italic text-xl tracking-tighter">SCHOOL LEAVE</div>
                        <button onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)} className="px-4 py-2 bg-blue-800 rounded-xl text-white flex items-center justify-center gap-2 shadow-sm active:scale-95 transition-transform min-w-[48px] min-h-[48px]">
                            <Icon name={isMobileMenuOpen ? "x" : "menu"} size={24} />
                            <span className="font-black text-sm tracking-widest">เมนู</span>
                        </button>
                    </div>

                    {/* Mobile Overlay Background */}
                    <div className={`md:hidden fixed inset-0 bg-slate-900/50 z-30 transition-opacity duration-300 ${isMobileMenuOpen ? 'opacity-100' : 'opacity-0 pointer-events-none'}`} onClick={() => setIsMobileMenuOpen(false)}></div>

                    {/* Sidebar (Responsive Layout) */}
                    <aside className={`fixed inset-y-0 left-0 z-40 w-72 bg-white border-r-2 border-slate-200 flex flex-col h-screen transform transition-transform duration-300 ease-in-out md:relative md:translate-x-0 ${isMobileMenuOpen ? 'translate-x-0' : '-translate-x-full'}`}>
