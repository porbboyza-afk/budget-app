async function genCoachPlan(){
  const dist=g('coach-dist'),weeks=g('coach-weeks'),days=g('coach-days');
  const hr=parseInt(g('coach-hr'))||0,min=parseInt(g('coach-min'))||0,sec=parseInt(g('coach-sec'))||0;
  if(!dist){ alert('กรุณากรอกระยะทาง'); return; }
  const d28=new Date(); d28.setDate(d28.getDate()-28);
  const recentRuns=DB.get('workouts',[]).filter(w=>w.activity==='run'&&new Date(w.date)>=d28);
  const avgVol=(recentRuns.reduce((s,w)=>s+(w.dist||0),0)/4).toFixed(1);
  const btn=document.getElementById('btn-coach');
  const out=document.getElementById('coach-plan-out');
  btn.innerHTML='⏳ กำลังสร้างตาราง...'; btn.disabled=true;
  try{
    const result=await callClaude([{role:'user',content:`สร้างตารางซ้อมวิ่ง:\n- เป้าหมาย: ${dist} กม. เวลา ${hr}ชม.${min}นาที${sec}วิ\n- ระยะเวลา: ${weeks} สัปดาห์\n- ซ้อม ${days} วัน/สัปดาห์\n- ฐานความฟิตปัจจุบัน: เฉลี่ย ${avgVol} กม./สัปดาห์\n\nจัดตารางเป็นตาราง markdown แสดง: สัปดาห์, วัน, ประเภท (Easy/Tempo/Long/Rest), ระยะทาง, Pace target`}],
      'คุณเป็นโค้ชวิทยาศาสตร์การกีฬา สร้างตารางซ้อมที่สมจริง ป้องกัน overtraining มีวันพัก และปรับตามฐานความฟิตที่ให้มา ตอบเป็นภาษาไทย');
    out.innerHTML=`<div class="ai-result" style="font-size:13px">${result.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div>`;
  } catch(e){ out.innerHTML=`<div class="ai-result" style="color:var(--accent4)">⚠️ ${e.message}</div>`; }
