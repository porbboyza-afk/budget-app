<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MyDashboard (Local & Claude AI)</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>
  /* ฟอนต์สำหรับหนังสือราชการ */
  @font-face {
    font-family: 'TH Sarabun New';
    src: local('TH Sarabun New'), local('THSarabunNew');
  }

  :root {
    --bg: #0f172a;        
    --surface: #1e293b;   
    --surface2: #334155;  
    --border: #475569;    
    --accent: #3b82f6;    
    --accent2: #10b981;   
    --accent3: #f59e0b;   
    --accent4: #ef4444;   
    --text: #f8fafc;      
    --text2: #94a3b8;     
    --text3: #64748b;     
    --run: #3b82f6;
  }
  
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Sarabun',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }

  ::-webkit-scrollbar { width: 6px; height: 8px; }
  ::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 10px; }

  /* SIDEBAR */
  .sidebar { position:fixed; left:0; top:0; bottom:0; width:240px; background:var(--surface); border-right:1px solid var(--border); display:flex; flex-direction:column; z-index:100; padding:24px 0; overflow-y:auto; }
  .logo { padding:0 20px 24px; border-bottom:1px solid var(--border); font-family:'Space Mono',monospace; font-size:20px; font-weight:700; color:var(--accent); letter-spacing:-0.5px; }
  .logo span { color:var(--text2); font-size:11px; display:block; font-weight:400; margin-top:2px; }
  .nav { flex:1; padding:16px 0; }
  .nav-item { display:flex; align-items:center; gap:12px; padding:12px 20px; cursor:pointer; color:var(--text2); font-size:14px; border-left:3px solid transparent; transition:all .2s; }
  .nav-item:hover, .nav-item.active { color:var(--text); background:var(--surface2); border-left-color:var(--accent); }
  .nav-item .icon { font-size:18px; }
  .nav-section { padding:12px 20px 4px; font-size:10px; letter-spacing:1.5px; color:var(--text3); text-transform:uppercase; margin-top:8px; font-weight:700; }

  /* MAIN */
  .main { margin-left:240px; padding:32px; min-height:100vh; }
  .page { display:none; animation: fadeIn 0.3s ease; }
  .page.active { display:block; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
  
  h1 { font-size:28px; font-weight:700; margin-bottom:4px; letter-spacing:-0.5px; }
  .subtitle { color:var(--text2); font-size:14px; margin-bottom:28px; }

  /* CARDS */
  .grid { display:grid; gap:20px; }
  .grid-2 { grid-template-columns:1fr 1fr; }
  .grid-3 { grid-template-columns:1fr 1fr 1fr; }
  .card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:24px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
  .card-title { font-size:12px; color:var(--text2); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px; }
  .stat-num { font-family:'Space Mono',monospace; font-size:32px; font-weight:700; color:var(--text); }

  .btn { padding:10px 20px; border-radius:10px; border:none; cursor:pointer; font-family:'Sarabun',sans-serif; font-size:14px; font-weight:600; transition:all .2s; }
  .btn-primary { background:var(--accent); color:#fff; }
  .btn-success { background:var(--accent2); color:#fff; }
  .btn-ghost { background:transparent; color:var(--text2); border:1px solid var(--border); }

  .form-group { margin-bottom:16px; }
  label { display:block; font-size:13px; color:var(--text2); margin-bottom:8px; font-weight:500; }
  input, select, textarea { width:100%; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:10px 14px; color:var(--text); font-family:'Sarabun',sans-serif; font-size:14px; transition:border-color .2s; outline:none; }
  input:focus, select:focus, textarea:focus { border-color:var(--accent); background:var(--surface); }

  .tabs { display:flex; gap:8px; margin-bottom:24px; border-bottom:1px solid var(--border); }
  .tab { padding:10px 20px; cursor:pointer; font-size:14px; font-weight:600; color:var(--text2); border-bottom:3px solid transparent; transition:all .2s; margin-bottom:-1px; }
  .tab.active { color:var(--accent); border-bottom-color:var(--accent); }

  .chart-wrap { position:relative; height:300px; }

  /* DOC PREVIEW */
  .doc-preview-container { background:#525659; padding:20px; border-radius:16px; overflow:auto; max-height:1000px; display:flex; justify-content:center; }
  .a4-sim { 
    width: 210mm; min-height: 297mm; height: auto; margin: 0 auto; 
    padding: 2.5cm 2cm 2cm 3cm; background: white; color: #000; 
    box-shadow: 0 0 10px rgba(0,0,0,0.5); font-family: 'TH Sarabun New', 'Sarabun', serif; 
    font-size: 16pt; font-weight: normal; line-height: 1.15; position: relative; 
    display: flex; flex-direction: column; box-sizing: border-box;
  }

  .ai-box { background:linear-gradient(135deg,rgba(59,130,246,.05),rgba(168,85,247,.05)); border:1px solid rgba(59,130,246,.3); border-radius:12px; padding:20px; margin-bottom: 20px; }
  .ai-bubble { background: var(--surface2); padding: 16px; border-radius: 12px; margin-top:12px; line-height:1.6; font-size:14px;}

  #sys-error-toast { display:none; position:fixed; bottom:20px; right:20px; background:#ef4444; color:#fff; padding:16px; border-radius:12px; z-index:9999; max-width:400px; font-family: 'Sarabun', sans-serif; }

  .flex { display:flex; }
  .items-center { align-items:center; }
  .justify-between { justify-content:space-between; }
  .mb-12 { margin-bottom:12px; }
  .mb-24 { margin-bottom:24px; }
  .mt-12 { margin-top:12px; }

  table { width:100%; border-collapse:collapse; }
  th { text-align:left; font-size:12px; color:var(--text3); padding:12px; border-bottom:2px solid var(--border); text-transform:uppercase; }
  td { padding:14px 12px; border-bottom:1px solid var(--border); font-size:14px; }
</style>
</head>
