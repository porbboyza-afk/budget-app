function printDoc() {
    const content = document.getElementById('doc-render-area').innerHTML;
    const win = window.open('', '_blank');
    win.document.write(`<html><head><style>@font-face{font-family:'TH Sarabun New';src:local('TH Sarabun New');}body{margin:0;} .print-area{width:210mm; min-height:297mm; padding:2.5cm 2cm 2cm 3cm; font-family:'TH Sarabun New',serif; font-size:16pt; color:#000; display:flex; flex-direction:column;}</style></head><body><div class="print-area">${content}</div><script>window.print();<\/script></body></html>`);
    win.document.close();
}

