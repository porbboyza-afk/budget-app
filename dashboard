<script>
// ========== GLOBAL ERROR HANDLING ==========
window.onerror = function(m, s, l, c, e) {
    const toast = document.getElementById('sys-error-toast');
    const msg = document.getElementById('sys-error-msg');
    if(toast && msg) {
        msg.textContent = `[Line ${l}] ${m}`;
        toast.style.display = 'block';
    }
    return false;
};

// ========== DATA LAYER ==========
function getData(k, d=[]) { try { return JSON.parse(localStorage.getItem(k)) || d; } catch { return d; } }
function setData(k, v) { localStorage.setItem(k, JSON.stringify(v)); }

// ========== CLAUDE AI INTEGRATION ==========
async function askClaude(prompt, systemMsg = "", btnId = "", isJson = false) {
    const apiKey = localStorage.getItem('claude_api_key');
    if (!apiKey) { alert("กรุณาตั้งค่า Claude API Key ในหน้าตั้งค่า"); showPage('settings'); return null; }

    const btn = btnId ? document.getElementById(btnId) : null;
    const oldTxt = btn?.innerText;
    if(btn) { btn.innerText = "⏳ Claude is thinking..."; btn.disabled = true; }

    try {
        const response = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': apiKey,
                'anthropic-version': '2023-06-01',
                'dangerously-allow-browser': 'true'
            },
            body: JSON.stringify({
                model: "claude-3-5-sonnet-20241022",
                max_tokens: 2048,
                system: systemMsg,
                messages: [{ role: "user", content: prompt }]
            })
        });

        if (!response.ok) {
            const err = await response.json();
            throw new Error(err.error?.message || "Connection Error");
        }

        const data = await response.json();
        if (!data.content || !data.content[0]) throw new Error("No response from AI");
        
        let result = data.content[0].text;

        if (isJson) {
            // Clean markdown and extract JSON
            result = result.replace(/```json\n?/gi, '').replace(/```\n?/gi, '').trim();
            return JSON.parse(result);
        }
        return result;

    } catch (e) {
        alert("Claude API Error: " + e.message);
        return null;
    } finally {
        if(btn) { btn.innerText = oldTxt; btn.disabled = false; }
    }
}

// ========== STATS ENGINE ==========
let activeChart = null;

function initStats() {
    renderWeekStats();
}

function switchStatsTab(tab, el) {
    document.querySelectorAll('#page-fitness-stats .tab').forEach(t=>t.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('stats-week-view').style.display = tab==='week'?'block':'none';
    document.getElementById('stats-month-view').style.display = tab==='month'?'block':'none';
    if(tab==='week') renderWeekStats();
    if(tab==='month') renderMonthStats();
}

function renderWeekStats() {
    const wks = getData('my_workouts');
    const labels = []; const dataPoints = [];
    let totalDist = 0;
    
    for(let i=6; i>=0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        const dateStr = d.toISOString().slice(0,10);
        labels.push(d.toLocaleDateString('th-TH', {day:'numeric', month:'short'}));
        const dayDist = wks.filter(w=>w.date===dateStr).reduce((s,w)=>s+parseFloat(w.dist||0),0);
        dataPoints.push(dayDist);
        totalDist += dayDist;
    }

    document.getElementById('stat-wk-dist').textContent = totalDist.toFixed(1) + ' กม.';
    document.getElementById('stat-wk-count').textContent = wks.filter(w => new Date(w.date) >= new Date(Date.now() - 7*86400000)).length + ' ครั้ง';

    if(activeChart) activeChart.destroy();
    const ctx = document.getElementById('chart-week-trend').getContext('2d');
    activeChart = new Chart(ctx, {
        type: 'bar',
        data: { labels, datasets: [{ label: 'ระยะทาง (กม.)', data: dataPoints, backgroundColor: '#3b82f6', borderRadius: 8 }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { grid: { color: '#334155' } }, x: { grid: { display: false } } } }
    });
}

function renderMonthStats() {
    const wks = getData('my_workouts');
    const labels = ['สัปดาห์ 1', 'สัปดาห์ 2', 'สัปดาห์ 3', 'สัปดาห์ 4'];
    const dataPoints = [0, 0, 0, 0];
    
    wks.forEach(w => {
        const d = new Date(w.date);
        const weekIdx = Math.floor((d.getDate() - 1) / 7);
        if(weekIdx < 4) dataPoints[weekIdx] += parseFloat(w.dist || 0);
    });

    const ctx = document.getElementById('chart-month-trend').getContext('2d');
    if(activeChart) activeChart.destroy();
    activeChart = new Chart(ctx, {
        type: 'line',
        data: { labels, datasets: [{ label: 'ระยะทางรวม (กม.)', data: dataPoints, borderColor: '#10b981', tension: 0.4, fill: true, backgroundColor: 'rgba(16, 185, 129, 0.1)' }] },
        options: { responsive: true, maintainAspectRatio: false }
    });
}

async function analyzeFitnessAI(type) {
    const wks = getData('my_workouts').slice(0, 10);
    const summary = wks.map(w => `${w.date}: ${w.dist}กม. ${w.time}นาที`).join(', ');
    const out = document.getElementById('ai-stats-output');
    out.style.display = 'block';
    out.innerText = "⏳ Claude กำลังวิเคราะห์แนวโน้มสุขภาพของคุณ...";
    const res = await askClaude(`ข้อมูลการซ้อมล่าสุด: ${summary}. ช่วยวิเคราะห์ Training Load และให้คำแนะนำการซ้อมแบบตรงไปตรงมา ไม่เยิ่นเย้อ 3 ข้อ`, "คุณคือผู้เชี่ยวชาญสรีรวิทยาการออกกำลังกาย", "btn-analyze-wk");
    if(res) out.innerText = res;
}

// ========== RENDER FUNCTIONS ==========
function renderToday() {
    const wks = getData('my_workouts');
    const docs = getData('my_docs');
    const totalDist = wks.filter(w => new Date(w.date) >= new Date(Date.now() - 7*86400000)).reduce((s, w) => s + parseFloat(w.dist || 0), 0);
    document.getElementById('t-distance').textContent = totalDist.toFixed(1);
    document.getElementById('t-docs').textContent = docs.length;
    
    const todayList = document.getElementById('today-recent-workouts');
    if(wks.length) {
        todayList.innerHTML = wks.slice(0, 3).map(w => `<div class="mb-12 text-sm">${w.date}: ${w.dist} กม.</div>`).join('');
    } else {
        todayList.innerHTML = '<p class="text2 text-sm">ยังไม่มีข้อมูล</p>';
    }
}

function renderDocList() {
    const list = getData('my_docs');
    const body = document.getElementById('doc-table-body');
    if(!list.length) { body.innerHTML = '<tr><td colspan="3">ไม่มีข้อมูล</td></tr>'; return; }
    body.innerHTML = list.map(d => `<tr><td>${d.num || '-'}</td><td>${d.date || '-'}</td><td>${d.sub || '-'}</td></tr>`).join('');
}

function renderRecentWorkouts() {
    const list = getData('my_workouts');
    const container = document.getElementById('recent-workouts-list');
    if(!list.length) { container.innerHTML = '<p class="text2 text-sm">ไม่มีข้อมูล</p>'; return; }
    container.innerHTML = list.slice(0, 5).map(w => `<div class="mb-12 text-sm">${w.date}: ${w.dist} กม. (${w.time} นาที)</div>`).join('');
}

// ========== NAVIGATION ==========
function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const pageEl = document.getElementById('page-'+id);
    if(pageEl) pageEl.classList.add('active');
    
    const navItems = document.querySelectorAll('.nav-item');
    const map = {today:0,'fitness-log':1,'fitness-stats':2,coach:3,'doc-summary':4,'doc-create':5,'doc-list':6,news:7,settings:8};
    if (navItems[map[id]]) navItems[map[id]].classList.add('active');

    if(id==='today') renderToday();
    if(id==='fitness-log') renderRecentWorkouts();
    if(id==='fitness-stats') initStats();
    if(id==='doc-create') updateDocPreview();
    if(id==='doc-list') renderDocList();
    if(id==='settings') document.getElementById('set-claude-key').value = localStorage.getItem('claude_api_key') || '';
}

// ========== ACTIONS ==========
function saveSettings() {
    localStorage.setItem('claude_api_key', document.getElementById('set-claude-key').value);
    alert('บันทึกการตั้งค่าแล้ว ✅');
}

function saveWorkout() {
    const date = document.getElementById('f-date').value || new Date().toISOString().slice(0,10);
    const dist = parseFloat(document.getElementById('r-distance').value) || 0;
    const time = parseFloat(document.getElementById('r-time').value) || 0;
    const workouts = getData('my_workouts');
    workouts.unshift({ id: Date.now(), date, dist, time });
    setData('my_workouts', workouts);
    renderRecentWorkouts(); renderToday();
    alert('บันทึกสำเร็จ ✅');
}

function saveDocDb() {
    const docs = getData('my_docs');
    docs.unshift({ id: Date.now(), num: document.getElementById('do-num').value, sub: document.getElementById('do-subject').value, date: document.getElementById('do-date').value });
    setData('my_docs', docs);
    alert('บันทึกทะเบียนหนังสือแล้ว ✅');
    renderDocList();
}

async function processImageWithAI(event) {
    const files = event.target.files;
    if (!files.length) return;
    const btn = document.getElementById('btn-sync-image');
    btn.innerText = "⏳ กำลังสกัดข้อมูล...";
    try {
        const prompt = "Extract running distance (km) and total time (minutes) from these images. Return ONLY JSON: {distance: number, time: number}";
        const res = await askClaude(prompt, "You are a fitness data extractor.", "btn-sync-image", true);
        if(res) {
            document.getElementById('r-distance').value = res.distance || 0;
            document.getElementById('r-time').value = res.time || 0;
        }
    } catch(e) { alert(e.message); } finally { btn.innerText = "📸 สกัดรูปภาพ (AI)"; }
}

async function askNews() {
    const q = document.getElementById('news-query').value || 'ข่าวเศรษฐกิจเทคโนโลยีวันนี้';
    const out = document.getElementById('news-output');
    out.style.display = 'block';
    out.innerText = "⏳ Claude กำลังรวบรวมข้อมูลข่าวสาร...";
    const res = await askClaude(q, "คุณคือผู้เชี่ยวชาญข่าวสาร สรุปข่าวจากเน็ต 3 ข้อสำคัญ พร้อมวิเคราะห์สั้นๆ เป็นภาษาไทย", "btn-news");
    if(res) out.innerText = res;
}

async function summarizeDoc() {
    const txt = document.getElementById('ai-doc-input').value;
    const out = document.getElementById('ai-doc-output-page');
    const res = await askClaude(txt, "สรุปสาระสำคัญของหนังสือราชการไทยให้เหลือ 3 ข้อสั้นๆ กระชับที่สุดเพื่อเสนอผู้บริหาร", "btn-doc-ai");
    if(res) { out.innerText = res; out.style.display = 'block'; }
}

async function generateTrainingPlan() {
    const goal = document.getElementById('coach-goal').value;
    const out = document.getElementById('coach-output');
    const res = await askClaude(goal, "คุณคือโค้ชวิ่งวิทยาศาสตร์การกีฬา วางแผนการซ้อมให้เป็นตารางรายวัน 7 วัน", "btn-coach");
    if(res) out.innerText = res;
}

// ========== DOC PREVIEW & PRINT ==========
function loadGaruda(e) {
    const reader = new FileReader();
    reader.onload = (ev) => {
        localStorage.setItem('garudaImg', ev.target.result);
        document.getElementById('garuda-preview-thumb').innerHTML = `<img src="${ev.target.result}" style="width:100%">`;
        updateDocPreview();
    };
    reader.readAsDataURL(e.target.files[0]);
}

function clearGaruda() { 
    localStorage.removeItem('garudaImg'); 
    document.getElementById('garuda-preview-thumb').innerHTML = ''; 
    updateDocPreview(); 
}

function switchDocTab(type, el) {
    currentDocType = type;
    document.querySelectorAll('#page-doc-create .tab').forEach(t=>t.classList.remove('active'));
    el.classList.add('active');
    updateDocPreview();
}

