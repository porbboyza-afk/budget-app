// RSS NEWS - ใช้หลาย proxy เพื่อแก้ปัญหา CORS
const RSS_SOURCES=[
  {tag:'IT',url:'https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml'},
  {tag:'IT',url:'https://feeds.arstechnica.com/arstechnica/technology-lab'},
  {tag:'เศรษฐกิจ',url:'https://www.bangkokpost.com/rss/data/business.xml'},
  {tag:'เศรษฐกิจ',url:'https://rss.nytimes.com/services/xml/rss/nyt/Business.xml'},
];
const PROXIES=[
  url=>`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(url)}&count=4`,
  url=>`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`,
];
async function fetchRSS(src){
  try{
    const res=await fetch(PROXIES[0](src.url));
    const data=await res.json();
    if(data.status==='ok') return data.items.map(i=>({tag:src.tag,title:i.title,date:new Date(i.pubDate).toLocaleDateString('th-TH'),url:i.link,desc:(i.description||'').replace(/<[^>]*>/g,'').slice(0,100)}));
  } catch(e){}
  return [];
}
async function loadNews(){
  const el=document.getElementById('news-list');
  el.innerHTML='<p class="text2 text-sm">⏳ กำลังโหลดข่าว...</p>';
  let all=[];
  const results=await Promise.allSettled(RSS_SOURCES.map(s=>fetchRSS(s)));
  results.forEach(r=>{ if(r.status==='fulfilled') all=all.concat(r.value); });
  if(!all.length){
    el.innerHTML=`<div class="card" style="text-align:center;padding:32px;">
      <div style="font-size:28px;margin-bottom:12px">⚠️</div>
      <div class="text2 text-sm">ไม่สามารถโหลดฟีดข่าวได้ในขณะนี้ (API rate limit หรือ network issue)<br>กรุณาใช้ <strong>AI ถาม-ตอบ</strong> ด้านบนแทนครับ</div>
    </div>`;
    return;
  }
  el.innerHTML=`<div class="grid g2">${all.map(n=>`
    <div class="news-card" onclick="window.open('${n.url}','_blank')">
      <div class="news-tag">${n.tag}</div>
      <div class="news-title">${n.title}</div>
      ${n.desc?`<div class="news-desc">${n.desc}...</div>`:''}
      <div class="news-date">${n.date}</div>
    </div>
  `).join('')}</div>`;
}

