  <div class="subtitle">จัดการ API Keys และค่าเริ่มต้น</div>
  <div class="grid g2">
    <div class="card">
      <div class="card-title">Claude API Key</div>
      <div class="form-group">
        <label>API Key (เก็บในเครื่องคุณเท่านั้น)</label>
        <input type="password" id="set-key" placeholder="sk-ant-api03-...">
      </div>
      <button class="btn btn-success w-full" onclick="saveSettings()">💾 บันทึก</button>
      <p class="text-xs text2 mt-8">ดูวิธีรับ API Key ได้ที่ <a href="https://console.anthropic.com" target="_blank" style="color:var(--accent)">console.anthropic.com</a></p>
    </div>
    <div class="card">
      <div class="card-title">ข้อมูลตั้งต้น (Auto-fill หนังสือราชการ)</div>
      <div class="form-group"><label>ชื่อโรงเรียน</label><input type="text" id="set-school" placeholder="โรงเรียน..."></div>
      <div class="form-group"><label>ที่อยู่</label><input type="text" id="set-addr"></div>
      <div class="form-group"><label>โทร.</label><input type="text" id="set-tel"></div>
      <div class="form-group"><label>ชื่อผู้อำนวยการ</label><input type="text" id="set-director"></div>
      <div class="form-group"><label>ตำแหน่งผู้ลงนาม</label><input type="text" id="set-dirpos" placeholder="ผู้อำนวยการโรงเรียน..."></div>
      <button class="btn btn-success w-full" onclick="saveSettings()">💾 บันทึก</button>
    </div>
  </div>
</div>

</main>

<!-- MODAL: EDIT WORKOUT -->
<div class="modal-bg" id="modal-edit">
  <div class="modal">
    <div class="modal-title">✏️ แก้ไขบันทึก</div>
    <div id="modal-edit-content"></div>
    <div class="flex gap-8 mt-16">
      <button class="btn btn-primary" onclick="saveEditWorkout()">บันทึก</button>
      <button class="btn btn-danger btn-sm" onclick="deleteWorkout()" id="btn-del-wk">ลบ</button>
      <button class="btn btn-ghost" onclick="closeModal('modal-edit')">ยกเลิก</button>
    </div>
  </div>
</div>

<script>
// ==================== DATA ====================
const DB = {
  get:(k,d=null)=>{ try{const v=localStorage.getItem(k); return v?JSON.parse(v):d;}catch{return d;}},
  set:(k,v)=>{ try{localStorage.setItem(k,JSON.stringify(v));}catch(e){console.warn('DB write fail',e);}},
  del:(k)=>localStorage.removeItem(k)
};

function apiKey(){ return DB.get('claude_api_key','')||''; }
function saveSettings(){
  DB.set('claude_api_key', document.getElementById('set-key').value.trim());
  const cfg = {school:g('set-school'),addr:g('set-addr'),tel:g('set-tel'),director:g('set-director'),dirpos:g('set-dirpos')};
  DB.set('school_cfg',cfg);
  alert('บันทึกแล้ว ✅');
}
function loadSettings(){
  document.getElementById('set-key').value = apiKey();
  const cfg = DB.get('school_cfg',{});
  Object.keys(cfg).forEach(k=>{ const el=document.getElementById('set-'+k); if(el) el.value=cfg[k]||''; });
}
function autoFillSchool(){
  const cfg = DB.get('school_cfg',{});
  if(cfg.school){ const el=document.getElementById('d-org'); if(el&&!el.value) el.value=cfg.school; }
  if(cfg.addr){ const el=document.getElementById('d-addr'); if(el&&!el.value) el.value=cfg.addr; }
  if(cfg.tel){ const el=document.getElementById('d-tel'); if(el&&!el.value) el.value=cfg.tel; }
  if(cfg.director){ const el=document.getElementById('d-signer'); if(el&&!el.value) el.value=cfg.director; }
  if(cfg.dirpos){ const el=document.getElementById('d-pos'); if(el&&!el.value) el.value=cfg.dirpos; }
  liveDoc();
}

// ==================== HELPERS ====================
function g(id){ const el=document.getElementById(id); return el?el.value:''; }
function today(){ return new Date().toISOString().slice(0,10); }
function fmtDate(d){ if(!d) return ''; return new Date(d).toLocaleDateString('th-TH',{day:'numeric',month:'short',year:'numeric'}); }
function fmtDateTH(d){
  if(!d) return ''; const months=['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
  const dt=new Date(d); return `${dt.getDate()} ${months[dt.getMonth()]} ${dt.getFullYear()+543}`;
}
function fmtPace(p){ if(!p||isNaN(p)) return '—'; const m=Math.floor(p); const s=Math.round((p-m)*60); return `${m}:${String(s).padStart(2,'0')}`; }
function paceToMin(s){ if(!s) return null; const p=s.split(/[:.]/); return p.length>=2?parseInt(p[0])+(parseInt(p[1])/60):null; }
function actName(a){ return {run:'วิ่ง',swim:'ว่ายน้ำ',bike:'ปั่น',weight:'เวท'}[a]||a; }
function actEmoji(a){ return {run:'🏃',swim:'🏊',bike:'🚴',weight:'🏋️'}[a]||'💪'; }
function actColor(a){ return {run:'var(--run)',swim:'var(--swim)',bike:'var(--bike)',weight:'var(--weight)'}[a]||'var(--accent)'; }
function actBg(a,op=.12){ const m={run:'88,166,255',swim:'57,197,207',bike:'210,153,34',weight:'188,140,255'}; return `rgba(${m[a]||'88,166,255'},${op})`; }

// ==================== NAV ====================
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const pg=document.getElementById('page-'+id);
  if(pg) pg.classList.add('active');
  const navMap={today:0,'fit-log':1,'fit-stats':2,'fit-coach':3,race:4,'doc-in':5,'doc-create':6,'doc-list':7,news:8,settings:9};
  const items=document.querySelectorAll('.nav-item');
  if(navMap[id]!==undefined) items[navMap[id]]?.classList.add('active');

  if(id==='today') renderToday();
  if(id==='fit-log'){ document.getElementById('f-date').value=today(); renderWkList(); }
  if(id==='fit-stats'){ initStats(); }
  if(id==='race') renderRacePage();
  if(id==='doc-create'){ autoFillSchool(); liveDoc(); }
  if(id==='doc-list') renderDocList();
  if(id==='news') loadNews();
  if(id==='settings') loadSettings();
}

// ==================== TODAY ====================
function renderToday(){
  document.getElementById('today-date').textContent = new Date().toLocaleDateString('th-TH',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  const wks=DB.get('workouts',[]); const docs=DB.get('documents',[]);
  const d7=new Date(); d7.setDate(d7.getDate()-7);
  const r7=wks.filter(w=>new Date(w.date)>=d7);
  const runs7=r7.filter(w=>w.activity==='run');
  document.getElementById('t-run').textContent=runs7.reduce((s,w)=>s+(parseFloat(w.dist)||0),0).toFixed(1);
  document.getElementById('t-run-count').textContent=`${runs7.length} ครั้ง`;
  document.getElementById('t-total').textContent=r7.length;
  document.getElementById('t-docs').textContent=docs.length;
  // recent workouts
  const rw=document.getElementById('today-workouts');
  if(!wks.length){ rw.innerHTML='<p class="text2 text-sm">ยังไม่มีข้อมูล</p>'; return; }
  rw.innerHTML=wks.slice(0,4).map(w=>`
    <div class="today-row">
      <div class="today-icon" style="background:${actBg(w.activity)}">${actEmoji(w.activity)}</div>
      <div style="flex:1">
        <div class="today-val">${actName(w.activity)} ${w.dist?w.dist+' กม.':''} ${w.time?'· '+w.time+' นาที':''}</div>
        <div class="today-sub">${fmtDate(w.date)}${w.avgPace?' · Pace '+fmtPace(w.avgPace):''}</div>
      </div>
    </div>
  `).join('');
  // race
  const race=DB.get('race',null);
  if(race&&race.date){
    const dl=Math.ceil((new Date(race.date)-new Date())/86400000);
    if(dl>0){
      document.getElementById('today-race-card').style.display='block';
      document.getElementById('today-race-info').innerHTML=`<div class="bold mb-4">${race.name}</div><span style="font-family:'Space Mono',monospace;font-size:28px;color:var(--accent5)">${dl}</span> <span class="text2">วัน</span>`;
    }
  }
}

// ==================== FITNESS LOG ====================
function onActChange(){
  const a=g('f-act');
  ['run','swim','bike','weight'].forEach(t=>{ const el=document.getElementById('f-'+t); if(el) el.classList.toggle('hidden',t!==a); });
  if(a!=='run') document.getElementById('splits-area').innerHTML='<p class="text-sm text2" style="font-style:italic">เลือกกิจกรรม "วิ่ง" เพื่อใช้ Splits</p>';
}

function buildSplits(){
  const dist=parseFloat(g('r-dist'));
  const area=document.getElementById('splits-area');
  if(!dist||dist<=0){ area.innerHTML=''; calcAvgPace(); return; }
  const n=Math.ceil(dist); let html=`
    <table class="splits-table">
      <thead><tr><th>กม.</th><th>Pace (น:ว)</th><th>HR (bpm)</th><th>หมายเหตุ</th></tr></thead>
      <tbody>`;
  for(let i=1;i<=n;i++){
    const lbl=i<n?`${i}`:`${i} (${dist%1?`+${(dist%1).toFixed(2).slice(1)}`:'ครบ'})`;
    html+=`<tr>
      <td class="mono bold" style="color:var(--accent)">${lbl}</td>
      <td><input type="text" class="sp-pace" placeholder="5:30" oninput="calcAvgPace()" style="width:80px"></td>
      <td><input type="number" class="sp-hr" placeholder="150" style="width:75px"></td>
      <td><input type="text" class="sp-note" placeholder="" style="width:90px"></td>
    </tr>`;
  }
  html+=`</tbody></table>`;
  area.innerHTML=html; calcAvgPace();
}

function calcAvgPace(){
  const paces=[...document.querySelectorAll('.sp-pace')];
  let total=0,cnt=0;
  paces.forEach(p=>{ const m=paceToMin(p.value); if(m) { total+=m; cnt++; }});
  const d=document.getElementById('avg-pace-disp');
  if(!cnt){ d.textContent='Pace เฉลี่ย: —'; return null; }
  const avg=total/cnt;
  d.textContent=`Pace เฉลี่ย: ${fmtPace(avg)}`;
  return avg;
}

function getSplits(){
  const rows=[...document.querySelectorAll('#splits-area tbody tr')];
  return rows.map((r,i)=>({
    km:i+1,
    pace:r.querySelector('.sp-pace')?.value||'',
    hr:parseInt(r.querySelector('.sp-hr')?.value)||0,
    note:r.querySelector('.sp-note')?.value||''
  })).filter(s=>s.pace||s.hr);
}

function saveWorkout(){
  const act=g('f-act');
  let w={id:Date.now(),activity:act,date:g('f-date')||today(),feel:g('f-feel'),ts:Date.now()};
  if(act==='run'){
    const dist=parseFloat(g('r-dist'));
    if(!dist){ alert('กรุณากรอกระยะทาง'); return; }
    const time=parseFloat(g('r-time'))||0;
    const avgPace=calcAvgPace()||(time>0&&dist>0?time/dist:0);
    w={...w,dist,time,avgPace,cad:parseInt(g('r-cad'))||0,stride:parseFloat(g('r-stride'))||0,hr:parseInt(g('r-hr'))||0,elev:parseInt(g('r-elev'))||0,note:g('r-note'),splits:getSplits()};
  } else if(act==='swim'){
    w={...w,dist:parseInt(g('sw-dist'))||0,time:parseFloat(g('sw-time'))||0,laps:parseInt(g('sw-laps'))||0,style:g('sw-style'),note:g('sw-note')};
  } else if(act==='bike'){
    const dist=parseFloat(g('bk-dist'))||0,time=parseFloat(g('bk-time'))||0;
    w={...w,dist,time,maxspd:parseFloat(g('bk-maxspd'))||0,hr:parseInt(g('bk-hr'))||0,avgspd:time>0?dist/(time/60):0,note:g('bk-note')};
  } else {
    w={...w,muscle:g('wt-muscle'),time:parseInt(g('wt-time'))||0,sets:parseInt(g('wt-sets'))||0,vol:parseInt(g('wt-vol'))||0,note:g('wt-note')};
  }
  const wks=DB.get('workouts',[]); wks.unshift(w); DB.set('workouts',wks);
  // reset form
  ['r-dist','r-time','r-cad','r-stride','r-hr','r-elev','r-note'].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; });
  document.getElementById('splits-area').innerHTML='<p class="text-sm text2" style="font-style:italic">กรอกระยะทางเพื่อสร้างช่อง Splits</p>';
  document.getElementById('avg-pace-disp').textContent='Pace เฉลี่ย: —';
  alert('บันทึกสำเร็จ ✅'); renderWkList(); renderToday();
}

function renderWkList(){
  const wks=DB.get('workouts',[]);
  const el=document.getElementById('wk-list');
  if(!wks.length){ el.innerHTML='<p class="text2 text-sm">ยังไม่มีข้อมูล</p>'; return; }
  el.innerHTML=`<table>
    <thead><tr><th>วัน</th><th>กิจกรรม</th><th>ระยะ/เวลา</th><th>Pace เฉลี่ย</th><th>HR</th><th></th></tr></thead>
    <tbody>${wks.slice(0,15).map(w=>`
      <tr>
        <td>${fmtDate(w.date)}</td>
        <td><span class="badge b-${w.activity}">${actEmoji(w.activity)} ${actName(w.activity)}</span></td>
        <td class="mono">${w.dist?w.dist+' กม.':''}${w.time?' · '+w.time+' นาที':''}</td>
        <td class="mono">${w.avgPace?fmtPace(w.avgPace):'—'}</td>
        <td class="mono">${w.hr||'—'}</td>
        <td>
          <button class="btn btn-ghost btn-xs" onclick="openEditWk(${w.id})">✏️</button>
          <button class="btn btn-ghost btn-xs" onclick="confirmDelWk(${w.id})">🗑️</button>
        </td>
      </tr>
    `).join('')}</tbody>
  </table>`;
}

let editWkId=null;
function openEditWk(id){
  const wks=DB.get('workouts',[]);
  const w=wks.find(x=>x.id===id);
  if(!w) return;
  editWkId=id;
  const el=document.getElementById('modal-edit-content');
  el.innerHTML=`
    <div class="grid g2">
      <div class="form-group"><label>วันที่</label><input type="date" id="ew-date" value="${w.date}"></div>
      <div class="form-group"><label>ระยะ</label><input type="number" step="0.01" id="ew-dist" value="${w.dist||''}"></div>
    </div>
    <div class="grid g2">
      <div class="form-group"><label>เวลา (นาที)</label><input type="number" step="0.1" id="ew-time" value="${w.time||''}"></div>
      <div class="form-group"><label>HR เฉลี่ย</label><input type="number" id="ew-hr" value="${w.hr||''}"></div>
    </div>
    <div class="form-group"><label>หมายเหตุ</label><textarea id="ew-note">${w.note||''}</textarea></div>
  `;
  document.getElementById('modal-edit').classList.add('open');
}
function saveEditWorkout(){
  const wks=DB.get('workouts',[]);
  const idx=wks.findIndex(x=>x.id===editWkId);
  if(idx<0) return;
  wks[idx]={...wks[idx],date:g('ew-date'),dist:parseFloat(g('ew-dist'))||wks[idx].dist,time:parseFloat(g('ew-time'))||wks[idx].time,hr:parseInt(g('ew-hr'))||wks[idx].hr,note:g('ew-note')};
  DB.set('workouts',wks); closeModal('modal-edit'); renderWkList(); renderToday();
}
function confirmDelWk(id){
  if(!confirm('ลบบันทึกนี้?')) return;
  const wks=DB.get('workouts',[]).filter(w=>w.id!==id);
  DB.set('workouts',wks); renderWkList(); renderToday();
}
function deleteWorkout(){
  confirmDelWk(editWkId); closeModal('modal-edit');
}

// ==================== STATS ====================
const charts={};
function destroyChart(id){ if(charts[id]){ charts[id].destroy(); delete charts[id]; }}
const chartOpts={responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#8b949e',font:{size:11}}}},scales:{x:{ticks:{color:'#8b949e'},grid:{color:'#30363d'}},y:{ticks:{color:'#8b949e'},grid:{color:'#30363d'}}}};

function initStats(){
  document.getElementById('st-day-pick').value=today();
  document.getElementById('st-week-pick').value=today();
  document.getElementById('st-month-pick').value=today().slice(0,7);
  renderDay();
}
function statTab(t,el){
  document.querySelectorAll('#page-fit-stats .tab').forEach(x=>x.classList.remove('active'));
  el.classList.add('active');
  ['day','week','month'].forEach(x=>{ document.getElementById('st-'+x).classList.toggle('hidden',x!==t); });
  if(t==='week') renderWeek();
  if(t==='month') renderMonth();
}

function renderDay(){
  const date=g('st-day-pick');
  const wks=DB.get('workouts',[]).filter(w=>w.date===date);
  const runs=wks.filter(w=>w.activity==='run');
  const totalDist=runs.reduce((s,w)=>s+(w.dist||0),0);
  const avgPaceVal=runs.length?runs.reduce((s,w)=>s+(w.avgPace||0),0)/runs.length:0;
  const avgHR=runs.length?Math.round(runs.reduce((s,w)=>s+(w.hr||0),0)/runs.length):0;
  document.getElementById('day-cards').innerHTML=`
    <div class="card card-run"><div class="card-title">ระยะวิ่ง</div><div class="stat-big">${totalDist.toFixed(2)}</div><div class="stat-unit">กม.</div></div>
    <div class="card"><div class="card-title">กิจกรรม</div><div class="stat-big">${wks.length}</div><div class="stat-unit">ครั้ง</div></div>
    <div class="card"><div class="card-title">Pace เฉลี่ย</div><div class="stat-big mono">${avgPaceVal?fmtPace(avgPaceVal):'—'}</div></div>
    <div class="card"><div class="card-title">HR เฉลี่ย</div><div class="stat-big">${avgHR||'—'}</div><div class="stat-unit">bpm</div></div>
  `;
  // splits charts — aggregate all runs of that day
  destroyChart('day-pace'); destroyChart('day-hr');
  let allSplits=[];
  runs.forEach(w=>{ if(w.splits) allSplits=allSplits.concat(w.splits); });
  if(allSplits.length){
    charts['day-pace']=new Chart(document.getElementById('ch-day-pace'),{type:'bar',data:{labels:allSplits.map(s=>`กม.${s.km}`),datasets:[{label:'Pace (น:ว)',data:allSplits.map(s=>paceToMin(s.pace)),backgroundColor:'rgba(88,166,255,.5)',borderColor:'var(--run)',borderWidth:2,borderRadius:4}]},options:{...chartOpts,plugins:{...chartOpts.plugins,tooltip:{callbacks:{label:ctx=>'Pace: '+fmtPace(ctx.raw)}}}}});
    charts['day-hr']=new Chart(document.getElementById('ch-day-hr'),{type:'line',data:{labels:allSplits.map(s=>`กม.${s.km}`),datasets:[{label:'HR (bpm)',data:allSplits.map(s=>s.hr||null),borderColor:'var(--accent4)',backgroundColor:'rgba(248,81,73,.1)',fill:true,tension:.35,pointRadius:4}]},options:{...chartOpts}});
  }
}

function getWeekDates(dateStr){
  const d=new Date(dateStr);
  const day=d.getDay(); const diff=day===0?-6:1-day;
  const mon=new Date(d); mon.setDate(d.getDate()+diff); mon.setHours(0,0,0,0);
  const sun=new Date(mon); sun.setDate(mon.getDate()+6); sun.setHours(23,59,59,999);
  return {start:mon,end:sun};
}

function renderWeek(){
  const {start,end}=getWeekDates(g('st-week-pick'));
  const wks=DB.get('workouts',[]).filter(w=>{ const d=new Date(w.date); return d>=start&&d<=end; });
  const days=['จ','อ','พ','พฤ','ศ','ส','อา'];
  const distData=Array(7).fill(0), timeData=Array(7).fill(0), paceData=Array(7).fill(null);
  const typeCounts={run:0,swim:0,bike:0,weight:0};
  wks.forEach(w=>{
    const di=new Date(w.date).getDay();
    const idx=di===0?6:di-1;
    if(w.activity==='run'||w.activity==='bike') distData[idx]+=(w.dist||0);
    timeData[idx]+=(w.time||0);
    if(typeCounts[w.activity]!==undefined) typeCounts[w.activity]++;
  });
  // avg pace per day
  days.forEach((_,idx)=>{
    const dayDate=new Date(start); dayDate.setDate(start.getDate()+idx);
    const dateStr=dayDate.toISOString().slice(0,10);
    const dayRuns=wks.filter(w=>w.activity==='run'&&w.date===dateStr);
    if(dayRuns.length) paceData[idx]=dayRuns.reduce((s,w)=>s+(w.avgPace||0),0)/dayRuns.length;
  });

  destroyChart('w-vol'); destroyChart('w-pace'); destroyChart('w-type');
  charts['w-vol']=new Chart(document.getElementById('ch-week-vol'),{type:'bar',data:{labels:days,datasets:[{label:'ระยะ (กม.)',data:distData.map(v=>+v.toFixed(2)),backgroundColor:'rgba(88,166,255,.6)',yAxisID:'y'},{label:'เวลา (นาที)',data:timeData,backgroundColor:'rgba(63,185,80,.4)',yAxisID:'y1',type:'line',fill:false,borderColor:'var(--accent2)',tension:.3}]},options:{...chartOpts,scales:{x:{ticks:{color:'#8b949e'},grid:{color:'#30363d'}},y:{position:'left',ticks:{color:'#8b949e'},grid:{color:'#30363d'}},y1:{position:'right',ticks:{color:'#8b949e'},grid:{drawOnChartArea:false}}}}});
  charts['w-pace']=new Chart(document.getElementById('ch-week-pace'),{type:'line',data:{labels:days,datasets:[{label:'Pace เฉลี่ย',data:paceData,borderColor:'var(--accent3)',backgroundColor:'rgba(210,153,34,.1)',fill:true,tension:.3,spanGaps:true,pointRadius:5}]},options:{...chartOpts,plugins:{...chartOpts.plugins,tooltip:{callbacks:{label:ctx=>ctx.raw?'Pace: '+fmtPace(ctx.raw):'ไม่มีข้อมูล'}}}}});
  charts['w-type']=new Chart(document.getElementById('ch-week-type'),{type:'doughnut',data:{labels:['วิ่ง','ว่ายน้ำ','ปั่น','เวท'],datasets:[{data:Object.values(typeCounts),backgroundColor:['rgba(88,166,255,.7)','rgba(57,197,207,.7)','rgba(210,153,34,.7)','rgba(188,140,255,.7)'],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'#8b949e'}}}}});
