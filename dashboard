    rb.onload=ev=>{ window._imgB64=ev.target.result.split(',')[1]; window._imgMime=f.type; document.getElementById('doc-in-text').value='[รูปภาพอัปโหลดแล้ว]'; };
    rb.readAsDataURL(f);
  }
}

