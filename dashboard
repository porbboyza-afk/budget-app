<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MyDash — ระบบส่วนตัว</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Space+Mono:wght@400;700&family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:#0d1117; --surface:#161b22; --surface2:#21262d; --surface3:#30363d;
  --border:#30363d; --border2:#484f58;
  --accent:#58a6ff; --accent2:#3fb950; --accent3:#d29922; --accent4:#f85149;
  --accent5:#bc8cff; --accent6:#39d353;
  --text:#e6edf3; --text2:#8b949e; --text3:#6e7681;
  --run:#58a6ff; --swim:#39c5cf; --bike:#d29922; --weight:#bc8cff;
  --grad1:linear-gradient(135deg,#1a1f2e,#0d1117);
  --shadow:0 8px 32px rgba(0,0,0,.4);
  --radius:14px; --radius-sm:8px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* SCROLLBAR */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:10px;}

/* SIDEBAR */
.sidebar{
  position:fixed;left:0;top:0;bottom:0;width:230px;
  background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;z-index:200;
  padding:0;overflow-y:auto;
  transition:transform .3s cubic-bezier(.4,0,.2,1);
}
.sidebar-header{
  padding:20px 20px 16px;
  border-bottom:1px solid var(--border);
  background:linear-gradient(135deg,rgba(88,166,255,.08),transparent);
}
.logo{font-family:'Space Mono',monospace;font-size:18px;font-weight:700;color:var(--accent);letter-spacing:-0.5px;}
.logo-sub{color:var(--text3);font-size:11px;margin-top:2px;font-family:'Sarabun',sans-serif;}
.nav{flex:1;padding:12px 0;}
.nav-section{padding:12px 16px 4px;font-size:9px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;font-weight:700;}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 16px;cursor:pointer;color:var(--text2);font-size:13.5px;
  border-left:2px solid transparent;
  transition:all .18s ease;border-radius:0 8px 8px 0;margin:1px 8px 1px 0;
}
.nav-item:hover{color:var(--text);background:var(--surface2);border-left-color:var(--border2);}
.nav-item.active{color:var(--accent);background:rgba(88,166,255,.1);border-left-color:var(--accent);}
.nav-item .ni{font-size:16px;width:20px;text-align:center;}

/* MAIN */
.main{margin-left:230px;padding:28px 32px;min-height:100vh;}
.page{display:none;animation:fadeSlide .3s ease;}
.page.active{display:block;}
@keyframes fadeSlide{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
h1{font-size:24px;font-weight:700;margin-bottom:4px;font-family:'Prompt',sans-serif;letter-spacing:-.3px;}
.subtitle{color:var(--text2);font-size:13px;margin-bottom:24px;}

/* GRID */
.grid{display:grid;gap:16px;}
.g2{grid-template-columns:1fr 1fr;}
.g3{grid-template-columns:1fr 1fr 1fr;}
.g4{grid-template-columns:repeat(4,1fr);}
.span2{grid-column:span 2;}

/* CARD */
.card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);padding:20px;
  transition:border-color .2s,box-shadow .2s;
}
.card:hover{border-color:var(--border2);}
.card-title{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:1.2px;font-weight:700;margin-bottom:14px;}
.stat-big{font-family:'Space Mono',monospace;font-size:30px;font-weight:700;}
.stat-unit{font-size:12px;color:var(--text2);margin-left:3px;}
.stat-sub{font-size:12px;color:var(--text3);margin-top:3px;}

/* GLOW CARDS */
.card-run{border-color:rgba(88,166,255,.25);background:linear-gradient(135deg,rgba(88,166,255,.05),var(--surface));}
.card-swim{border-color:rgba(57,197,207,.25);background:linear-gradient(135deg,rgba(57,197,207,.05),var(--surface));}
.card-bike{border-color:rgba(210,153,34,.25);background:linear-gradient(135deg,rgba(210,153,34,.05),var(--surface));}
.card-weight{border-color:rgba(188,140,255,.25);background:linear-gradient(135deg,rgba(188,140,255,.05),var(--surface));}
.card-ai{border-color:rgba(88,166,255,.3);background:linear-gradient(135deg,rgba(88,166,255,.06),rgba(188,140,255,.04),var(--surface));}

/* BTN */
.btn{padding:8px 18px;border-radius:var(--radius-sm);border:none;cursor:pointer;font-family:'Sarabun',sans-serif;font-size:13.5px;font-weight:600;transition:all .18s ease;display:inline-flex;align-items:center;gap:6px;}
.btn:active{transform:scale(.97);}
.btn-primary{background:var(--accent);color:#0d1117;}
.btn-primary:hover{background:#79b8ff;box-shadow:0 0 16px rgba(88,166,255,.35);}
.btn-success{background:var(--accent2);color:#0d1117;}
.btn-success:hover{background:#56d364;}
.btn-warn{background:var(--accent3);color:#0d1117;}
.btn-danger{background:var(--accent4);color:#fff;}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border);}
.btn-ghost:hover{color:var(--text);border-color:var(--border2);background:var(--surface2);}
.btn-sm{padding:5px 12px;font-size:12.5px;}
.btn-xs{padding:3px 9px;font-size:11.5px;}

/* FORM */
.form-group{margin-bottom:14px;}
label{display:block;font-size:12.5px;color:var(--text2);margin-bottom:6px;font-weight:500;}
input,select,textarea{
  width:100%;background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:8px 12px;color:var(--text);
  font-family:'Sarabun',sans-serif;font-size:13.5px;outline:none;
  transition:border-color .2s,background .2s;
}
input:focus,select:focus,textarea:focus{border-color:var(--accent);background:var(--surface3);}
textarea{resize:vertical;min-height:72px;line-height:1.5;}
select option{background:var(--surface2);}
input[type=file]{display:none;}

/* TABS */
.tabs{display:flex;gap:2px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;}
.tab{padding:8px 16px;cursor:pointer;font-size:13px;font-weight:600;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;border-radius:6px 6px 0 0;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);background:rgba(88,166,255,.06);}
.tab:hover:not(.active){color:var(--text);background:var(--surface2);}

/* TABLE */
table{width:100%;border-collapse:collapse;}
th{text-align:left;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--text3);padding:10px 12px;border-bottom:1px solid var(--border);font-weight:700;}
td{padding:11px 12px;border-bottom:1px solid var(--border);font-size:13px;color:var(--text);}
tr:hover td{background:var(--surface2);}
tr:last-child td{border-bottom:none;}

/* BADGE */
.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;}
.b-run{background:rgba(88,166,255,.15);color:var(--run);}
.b-swim{background:rgba(57,197,207,.15);color:var(--swim);}
.b-bike{background:rgba(210,153,34,.15);color:var(--bike);}
.b-weight{background:rgba(188,140,255,.15);color:var(--weight);}
.b-out{background:rgba(248,81,73,.12);color:var(--accent4);}
.b-memo{background:rgba(210,153,34,.12);color:var(--accent3);}
.b-green{background:rgba(63,185,80,.12);color:var(--accent2);}

/* CHART */
.chart-wrap{position:relative;height:220px;}
.chart-wrap-lg{position:relative;height:300px;}

/* NEWS CARD */
.news-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius);padding:16px;margin-bottom:10px;
  cursor:pointer;transition:all .2s;
}
.news-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:var(--shadow);}
.news-tag{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--accent);}
.news-title{font-size:14px;font-weight:600;margin:5px 0;line-height:1.4;}
.news-desc{font-size:12px;color:var(--text2);line-height:1.5;margin:4px 0;}
.news-date{font-size:11px;color:var(--text3);}

/* AI RESULT BOX */
.ai-result{
  background:var(--surface2);border:1px solid rgba(88,166,255,.2);
  border-radius:var(--radius);padding:16px;margin-top:12px;
  font-size:13.5px;line-height:1.7;white-space:pre-wrap;
  animation:fadeSlide .3s ease;
}

/* SPLITS TABLE */
.splits-table{width:100%;border-collapse:collapse;font-size:12.5px;}
.splits-table th{padding:6px 8px;font-size:10.5px;text-align:center;}
.splits-table td{padding:4px;text-align:center;}
.splits-table input{padding:5px 8px;font-size:12.5px;text-align:center;}

/* MODAL */
.modal-bg{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);
  z-index:500;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.modal-bg.open{display:flex;animation:fadeSlide .2s ease;}
.modal{
  background:var(--surface);border:1px solid var(--border);
  border-radius:18px;padding:28px;width:540px;max-width:95vw;
  max-height:90vh;overflow-y:auto;
  box-shadow:var(--shadow);
}
.modal-title{font-size:17px;font-weight:700;margin-bottom:18px;font-family:'Prompt',sans-serif;}

/* RACE COUNTDOWN */
.count-num{font-family:'Space Mono',monospace;font-size:36px;font-weight:700;color:var(--accent5);line-height:1;}
.count-label{font-size:10px;color:var(--text3);margin-top:2px;}

/* DOC PREVIEW — A4 */
.doc-bg{background:#525659;padding:20px;border-radius:14px;overflow:auto;max-height:820px;display:flex;justify-content:center;}
.a4{
  width:210mm;min-height:297mm;
  padding:2.5cm 2cm 2cm 3cm;
  background:#fff;color:#000;
  font-family:'TH Sarabun New','Sarabun',serif;
  font-size:16pt;line-height:1.5;
  box-shadow:0 4px 24px rgba(0,0,0,.3);
  flex-shrink:0;
}

/* GARUDA BAR */
.garuda-bar{
  background:linear-gradient(135deg,rgba(210,153,34,.06),var(--surface));
  border:1px solid rgba(210,153,34,.25);
  border-radius:var(--radius);padding:16px;margin-bottom:18px;
}

/* TODAY ROW */
.today-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.today-row:last-child{border-bottom:none;}
.today-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.today-val{font-size:14px;font-weight:600;}
.today-sub{font-size:12px;color:var(--text2);}

/* PROGRESS */
.progress-wrap{margin:6px 0;}
.progress-label{display:flex;justify-content:space-between;font-size:11.5px;color:var(--text2);margin-bottom:4px;}
.progress-track{height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.progress-fill{height:100%;border-radius:3px;transition:width .6s ease;}

/* PDF UPLOAD */
.pdf-drop{
  border:2px dashed var(--border);border-radius:var(--radius);
  padding:32px;text-align:center;cursor:pointer;
  transition:all .2s;color:var(--text2);font-size:13px;
}
.pdf-drop:hover{border-color:var(--accent);color:var(--text);background:rgba(88,166,255,.04);}
.pdf-drop.dragover{border-color:var(--accent);background:rgba(88,166,255,.08);}

/* UTIL */
.flex{display:flex;}.items-center{align-items:center;}.justify-between{justify-content:space-between;}
.gap-8{gap:8px;}.gap-12{gap:12px;}.gap-16{gap:16px;}
.mt-8{margin-top:8px;}.mt-12{margin-top:12px;}.mt-16{margin-top:16px;}.mt-20{margin-top:20px;}
.mb-8{margin-bottom:8px;}.mb-12{margin-bottom:12px;}.mb-16{margin-bottom:16px;}.mb-20{margin-bottom:20px;}
.text-xs{font-size:11.5px;}.text-sm{font-size:13px;}.text2{color:var(--text2);}.text3{color:var(--text3);}
.mono{font-family:'Space Mono',monospace;}.bold{font-weight:700;}
.w-full{width:100%;}.text-center{text-align:center;}
.hidden{display:none!important;}
.spin{animation:spin 1s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* RESPONSIVE */
@media(max-width:960px){
  .g3{grid-template-columns:1fr 1fr;}.g4{grid-template-columns:1fr 1fr;}
}
@media(max-width:700px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;padding:16px;}
  .g2,.g3,.g4{grid-template-columns:1fr;}
  .span2{grid-column:span 1;}
}
</style>
</head>
<body>

<!-- SIDEBAR -->
<nav class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo">MyDash</div>
    <div class="logo-sub">ระบบส่วนตัว — Local First</div>
  </div>
  <div class="nav">
    <div class="nav-section">หน้าหลัก</div>
    <div class="nav-item active" onclick="showPage('today')"><span class="ni">🏠</span>Today</div>

    <div class="nav-section">ออกกำลังกาย</div>
    <div class="nav-item" onclick="showPage('fit-log')"><span class="ni">📝</span>บันทึกการออกกำลังกาย</div>
    <div class="nav-item" onclick="showPage('fit-stats')"><span class="ni">📊</span>สถิติ & กราฟ</div>
    <div class="nav-item" onclick="showPage('fit-coach')"><span class="ni">🤖</span>AI โค้ชวางแผน</div>
    <div class="nav-item" onclick="showPage('race')"><span class="ni">🏆</span>การแข่งขัน</div>

    <div class="nav-section">งานธุรการ</div>
    <div class="nav-item" onclick="showPage('doc-in')"><span class="ni">📥</span>AI สรุปหนังสือเข้า</div>
    <div class="nav-item" onclick="showPage('doc-create')"><span class="ni">📤</span>สร้างหนังสือออก</div>
    <div class="nav-item" onclick="showPage('doc-list')"><span class="ni">📁</span>ทะเบียนหนังสือ</div>

    <div class="nav-section">ข้อมูล & AI</div>
    <div class="nav-item" onclick="showPage('news')"><span class="ni">📰</span>ข่าวสาร & AI ถาม-ตอบ</div>
    <div class="nav-item" onclick="showPage('settings')"><span class="ni">⚙️</span>ตั้งค่า</div>
  </div>
</nav>

<!-- MAIN -->
<main class="main">

<!-- ========== TODAY ========== -->
<div class="page active" id="page-today">
  <h1>สวัสดีครับ 👋</h1>
  <div class="subtitle" id="today-date"></div>

  <div class="grid g3 mb-16">
    <div class="card card-run">
      <div class="card-title">วิ่ง 7 วัน</div>
      <div class="stat-big" id="t-run">0.0</div>
      <div class="stat-unit" style="display:inline">กม.</div>
      <div class="stat-sub" id="t-run-count">0 ครั้ง</div>
    </div>
    <div class="card">
      <div class="card-title">ออกกำลังกาย 7 วัน</div>
      <div class="stat-big" id="t-total">0</div>
      <div class="stat-unit" style="display:inline">ครั้ง</div>
    </div>
    <div class="card">
      <div class="card-title">หนังสือที่บันทึก</div>
      <div class="stat-big" id="t-docs">0</div>
      <div class="stat-unit" style="display:inline">ฉบับ</div>
    </div>
  </div>

  <div class="grid g2">
    <div class="card">
      <div class="flex justify-between items-center mb-12">
        <div class="card-title" style="margin:0">บันทึกล่าสุด</div>
        <button class="btn btn-ghost btn-sm" onclick="showPage('fit-log')">+ เพิ่ม</button>
      </div>
      <div id="today-workouts"><p class="text2 text-sm">ยังไม่มีข้อมูล</p></div>
    </div>
    <div>
      <div class="card card-ai mb-16" id="today-race-card" style="display:none">
        <div class="card-title" style="color:var(--accent5);margin-bottom:8px">🏁 การแข่งขันถัดไป</div>
        <div id="today-race-info"></div>
      </div>
      <div class="card card-ai">
        <div class="card-title" style="color:var(--accent);margin-bottom:6px">🤖 Claude AI พร้อมใช้งาน</div>
        <p class="text-sm text2" style="line-height:1.7">ระบบใช้ Claude API — ใส่ API Key ในตั้งค่าเพื่อเปิดใช้ฟีเจอร์ AI ทุกส่วน ข้อมูลทั้งหมดเก็บในเครื่องของคุณ</p>
        <button class="btn btn-ghost btn-sm mt-8" onclick="showPage('settings')">⚙️ ตั้งค่า API</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== FITNESS LOG ========== -->
<div class="page" id="page-fit-log">
  <div class="flex justify-between items-center mb-20">
    <div>
      <h1>บันทึกการออกกำลังกาย</h1>
      <div class="subtitle" style="margin:0">วิ่ง • ว่ายน้ำ • ปั่น • เวท — พร้อม Splits รายกิโล</div>
    </div>
  </div>

  <div class="grid g2">
    <!-- FORM -->
    <div class="card">
      <div class="card-title">เพิ่มบันทึกใหม่</div>
      <div class="grid g2">
        <div class="form-group">
          <label>วันที่</label>
          <input type="date" id="f-date">
        </div>
        <div class="form-group">
          <label>กิจกรรม</label>
          <select id="f-act" onchange="onActChange()">
            <option value="run">🏃 วิ่ง</option>
            <option value="swim">🏊 ว่ายน้ำ</option>
            <option value="bike">🚴 ปั่นจักรยาน</option>
            <option value="weight">🏋️ เวทเทรนนิ่ง</option>
          </select>
        </div>
      </div>

      <!-- RUN -->
      <div id="f-run">
        <div class="grid g2">
          <div class="form-group">
            <label>ระยะทาง (กม.)</label>
            <input type="number" step="0.01" id="r-dist" placeholder="6.50" oninput="buildSplits()">
          </div>
          <div class="form-group">
            <label>เวลารวม (นาที)</label>
            <input type="number" step="0.1" id="r-time" placeholder="35.0">
          </div>
        </div>
        <div class="grid g2">
          <div class="form-group">
            <label>รอบขา (spm)</label>
            <input type="number" id="r-cad" placeholder="170">
          </div>
          <div class="form-group">
            <label>ระยะก้าว (ซม.)</label>
            <input type="number" step="0.1" id="r-stride" placeholder="95">
          </div>
        </div>
        <div class="grid g2">
          <div class="form-group">
            <label>HR เฉลี่ย (bpm)</label>
            <input type="number" id="r-hr" placeholder="150">
          </div>
          <div class="form-group">
            <label>ระดับความสูงขึ้น (ม.)</label>
            <input type="number" id="r-elev" placeholder="80">
          </div>
        </div>

        <!-- SPLITS -->
        <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:14px;">
          <div class="flex justify-between items-center mb-8">
            <span style="font-size:12px;font-weight:700;color:var(--accent)">⚡ Splits รายกิโลเมตร</span>
            <div id="avg-pace-disp" class="text-xs mono" style="color:var(--accent2)">Pace เฉลี่ย: —</div>
          </div>
          <div id="splits-area"><p class="text-sm text2" style="font-style:italic">กรอกระยะทางเพื่อสร้างช่อง Splits</p></div>
        </div>
        <div class="form-group">
          <label>หมายเหตุ / เส้นทาง</label>
          <textarea id="r-note" placeholder="เช่น วิ่งในสวนสาธารณะ..."></textarea>
        </div>
      </div>

      <!-- SWIM -->
      <div id="f-swim" class="hidden">
        <div class="grid g2">
          <div class="form-group"><label>ระยะ (ม.)</label><input type="number" id="sw-dist" placeholder="1000"></div>
          <div class="form-group"><label>เวลา (นาที)</label><input type="number" step="0.1" id="sw-time" placeholder="30"></div>
        </div>
        <div class="grid g2">
          <div class="form-group"><label>จำนวนเลน</label><input type="number" id="sw-laps" placeholder="20"></div>
          <div class="form-group"><label>ท่าว่าย</label>
            <select id="sw-style">
              <option value="freestyle">ฟรีสไตล์</option>
